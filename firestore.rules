rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- MODULE TI-PANIÉ SOLIDAIRE ---
    
    // Paniers : Tout le monde peut voir les offres disponibles
    match /paniers/{panierId} {
      allow read: if true; 
      allow write: if false; // Verrouillé pour éviter les fausses annonces
    }
    
    // Producteurs : Tout le monde peut voir la liste des partenaires vérifiés
    match /producteurs/{producteurId} {
      allow read: if true;
      allow write: if false; // Verrouillé pour garantir l'identité des producteurs
    }

    // --- MODULES EXISTANTS (RAPPEL) ---
    
    // Produits et Prix : Lecture seule pour le public
    match /products/{ean} {
      allow read: if true;
      allow write: if false;
    }
    
    match /prices/{priceId} {
      allow read: if true;
      allow write: if false;
    }


    // Prix locaux normalisés : lecture publique, écriture authentifiée
    match /price_observations/{observationId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /price_aggregates/{barcode}/territories/{territory} {
      allow read: if true;
      allow write: if false;
    }

    match /price_timeseries/{barcode}/territories/{territory}/days/{day} {
      allow read: if true;
      allow write: if false;
    }

    // Utilisateurs : lecture par l'utilisateur lui-même ou par un admin.
    // Écriture : l'utilisateur peut modifier ses propres données mais pas les champs de rôle
    // (role, roleUpdatedAt, roleUpdatedBy) — réservés à la Cloud Function setUserRole via Admin SDK.
    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId || request.auth.token.role == "admin");

      allow create: if request.auth != null;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    // Note: Firestore Rules do not support local variable extraction, so
                    // diff(resource.data).changedKeys() is necessarily repeated per field.
                    // Each condition independently blocks direct writes to role-related fields;
                    // only the Cloud Function (Admin SDK) can set these via setUserRole().
                    && !("role" in request.resource.data.diff(resource.data).changedKeys())
                    && !("roleUpdatedAt" in request.resource.data.diff(resource.data).changedKeys())
                    && !("roleUpdatedBy" in request.resource.data.diff(resource.data).changedKeys());

      allow delete: if false;
    }

    // Audit logs : lecture réservée aux admins, écriture bloquée côté client
    // (uniquement via Admin SDK dans les Cloud Functions setUserRole et set-creator-role.mjs).
    match /auditLogs/{logId} {
      allow read: if request.auth != null && request.auth.token.role == "admin";
      allow write: if false;
    }

    // Tickets de caisse (OCR) : Seul l'utilisateur peut uploader son ticket
    match /receipts/{receiptId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId != null && request.auth.uid == resource.data.userId;
      allow update: if false; // Only via admin/cloud functions
    }
    
    // Messages de contact : Tout le monde peut créer, seuls les admins peuvent lire
    // Validation de la structure du document pour prévenir les abus
    match /contact_messages/{messageId} {
      allow read: if request.auth != null
                  && (request.auth.token.role == "admin" || request.auth.token.admin == true);
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
                    && request.resource.data.keys().hasOnly(['name', 'email', 'message', 'subject', 'territory', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 2
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 254
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.message is string
                    && request.resource.data.message.size() >= 10
                    && request.resource.data.message.size() <= 2000
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.createdAt == request.time
                    && (!('subject' in request.resource.data) || (request.resource.data.subject is string && request.resource.data.subject.size() <= 200))
                    && (!('territory' in request.resource.data) || (request.resource.data.territory is string && request.resource.data.territory.size() <= 50));
      allow update: if request.auth != null
                    && (request.auth.token.role == "admin" || request.auth.token.admin == true);
      allow delete: if false; // Prevent deletion for audit trail
    }
    
    // Stores: read-only for all (price comparison feature)
    match /stores/{storeId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Visitor presence (temps réel) ──────────────────────────────────────
    // Each browser session writes/updates its own presence document.
    // Used to count online visitors per territory.
    // Documents are auto-cleaned on tab close (client deleteDoc).
    match /presence/{sessionId} {
      allow read: if true;
      // Any client may create/update its own session document
      // territory must be a known DOM-TOM code; page must be a short string
      allow create, update: if request.resource.data.keys().hasOnly(['territory', 'page', 'lastSeen'])
                            && request.resource.data.territory is string
                            && request.resource.data.territory in ['GP','MQ','GF','RE','YT','PM','NC','PF','WF','FR','BL','MF','PM']
                            && request.resource.data.page is string
                            && request.resource.data.page.size() <= 120
                            && request.resource.data.lastSeen is timestamp;
      allow delete: if true; // Client cleans up on tab close
    }

    // ── Visit stats per territory ───────────────────────────────────────────
    // Atomic increment counter per territory code document.
    // Public read — visitors can see total counts.
    match /visit_stats/{territory} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['totalVisits', 'lastVisit'])
                   && request.resource.data.totalVisits == 1;
      // Only allow incrementing by 1 — prevents tampering with the counter
      // lastVisit must be a recent server timestamp (within 5 minutes)
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalVisits', 'lastVisit'])
                   && request.resource.data.totalVisits == resource.data.totalVisits + 1
                   && request.resource.data.lastVisit is timestamp
                   && request.resource.data.lastVisit <= request.time
                   && request.resource.data.lastVisit >= request.time - duration.value(300, 's');
    }

    // ── Page / interest stats ───────────────────────────────────────────────
    // Atomic increment counter per page-category document.
    // Used for the "centres d'intérêt" podium.
    match /page_stats/{categoryKey} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['totalViews', 'name', 'emoji', 'lastView'])
                   && request.resource.data.totalViews == 1;
      // Only allow incrementing by 1 — prevents tampering with the counter
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalViews', 'name', 'emoji', 'lastView'])
                   && request.resource.data.totalViews == resource.data.totalViews + 1;
    }

    // ── Automatisation IA — Lecture publique, écriture Admin SDK uniquement ──
    // Les collections suivantes sont écrites exclusivement par les scripts
    // GitHub Actions via le Firebase Admin SDK (pas de règles client).

    match /monitoring/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK uniquement
    }

    match /scraping_sessions/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK uniquement
    }

    match /price_shocks/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK uniquement
    }

    match /price_shocks_analysis/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK uniquement
    }

    match /fuel_prices_snapshots/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK uniquement
    }

    match /fuel_prices_monthly/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK uniquement
    }

    match /observatory_snapshots/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK uniquement
    }

    match /food_price_observations/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK uniquement
    }

    function isAllowedClickEventTerritory(territory) {
      return territory is string
             && ['gp', 'mq', 'gf', 're', 'yt', 'guadeloupe', 'martinique', 'guyane', 'reunion', 'mayotte']
                  .hasAny([territory.lower()]);
    }

    function isOptionalBoundedString(data, field, maxLen) {
      return !data.keys().hasAny([field])
             || (data[field] is string && data[field].size() > 0 && data[field].size() <= maxLen);
    }

    // Click events — écriture anonyme autorisée, lecture interdite (admin seulement)
    match /click_events/{docId} {
      allow create: if request.resource.data.keys().hasAll(['retailer', 'territory', 'price', 'clickedAt'])
                    && request.resource.data.keys().hasOnly(['retailer', 'territory', 'price', 'clickedAt', 'barcode', 'pageUrl', 'sessionId'])
                    && request.resource.data.retailer is string
                    && request.resource.data.retailer.size() > 0
                    && request.resource.data.retailer.size() <= 100
                    && isAllowedClickEventTerritory(request.resource.data.territory)
                    && request.resource.data.price is number
                    && request.resource.data.price >= 0
                    && request.resource.data.price <= 10000
                    && request.resource.data.clickedAt is timestamp
                    && request.resource.data.clickedAt == request.time
                    && isOptionalBoundedString(request.resource.data, 'barcode', 128)
                    && isOptionalBoundedString(request.resource.data, 'pageUrl', 2048)
                    && isOptionalBoundedString(request.resource.data, 'sessionId', 128);
      allow read: if false; // lecture via Admin SDK seulement
    }
  }
}