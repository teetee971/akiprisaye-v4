# Open Data Exports
exports/

# ═══════════════════════════════════════════════════════════════
# GARDE-FOU ANTI-POLLUTION — Assets lourds et fichiers marketing
# ═══════════════════════════════════════════════════════════════
# Les assets doivent être sur CDN (Cloudflare R2) ou dans public/

# Design/Marketing source files (TOUJOURS sur CDN, jamais dans Git)
*.psd
*.ai
*.fig
*.sketch
*.xd

# Archives (JAMAIS dans le dépôt)
*.7z

# Vidéos (TOUJOURS sur CDN)
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Dossiers interdits (pollution repository)
backup/
old/
archive/
export/
extract/
final/
draft/
history/

