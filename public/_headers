/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-DNS-Prefetch-Control: on
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; frame-src 'self' https://*.firebaseapp.com; img-src 'self' data: https: https://github.com https://githubusercontent.com https://i.ytimg.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' https:; manifest-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site

/data/territories/*
  Cache-Control: public, max-age=86400, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=600

/assets/placeholders/*.svg
  Content-Type: image/svg+xml; charset=utf-8

/api/*
  Cache-Control: no-store, max-age=0, must-revalidate
  Pragma: no-cache
