{
  "name": "A KI PRI SA YÉ",
  "short_name": "AKPSY",
  "description": "Application citoyenne pour lutter contre la vie chère dans les Outre-mer. Comparez les prix, scannez vos tickets et gérez votre budget facilement.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#121212",
  "theme_color": "#0f62fe",
  "lang": "fr-FR",
  "orientation": "portrait-primary",
  "scope": "/",
  "categories": ["finance", "utilities", "shopping", "lifestyle"],
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/public/assets/icon_192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/public/assets/icon_256.png",
      "sizes": "256x256",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/public/assets/icon_512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "/public/assets/screenshot-mobile.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Comparateur de prix mobile"
    }
  ],
  "shortcuts": [
    {
      "name": "Comparateur de prix",
      "short_name": "Comparateur",
      "description": "Comparer les prix des produits rapidement",
      "url": "/comparateur.html",
      "icons": [
        {
          "src": "/public/assets/icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Scanner",
      "short_name": "Scanner",
      "description": "Scanner un code-barres pour comparer les prix",
      "url": "/scanner.html",
      "icons": [
        {
          "src": "/public/assets/icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Actualités",
      "short_name": "News",
      "description": "Voir les actualités sur les prix",
      "url": "/actualites.html",
      "icons": [
        {
          "src": "/public/assets/icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Carte",
      "short_name": "Carte",
      "description": "Localiser les magasins près de vous",
      "url": "/carte.html",
      "icons": [
        {
          "src": "/public/assets/icon_192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/jpeg", "image/png", "image/webp"]
        }
      ]
    }
  },
  "prefer_related_applications": false,
  "related_applications": []
}