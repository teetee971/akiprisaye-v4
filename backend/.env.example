# ========================================
# Configuration Backend - A KI PRI SA YÉ
# ========================================
# 
# ⚠️ NE JAMAIS COMMITTER CE FICHIER AVEC DES VRAIES VALEURS
# Copier vers .env et remplir avec vos vraies valeurs
#

# ========================================
# Base de données PostgreSQL
# ========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Exemple local: postgresql://akiprisaye:password@localhost:5432/akiprisaye_db?schema=public
# Exemple cloud: postgresql://user:pass@db.example.com:5432/prod_db?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/akiprisaye?schema=public"

# ========================================
# Configuration du serveur
# ========================================
NODE_ENV="development"
PORT="3001"
HOST="0.0.0.0"

# ========================================
# Sécurité JWT
# ========================================
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# Durée de validité des tokens
ACCESS_TOKEN_EXPIRY="15m"    # Access token: 15 minutes
REFRESH_TOKEN_EXPIRY="7d"    # Refresh token: 7 jours

# ========================================
# CORS - Origines autorisées
# ========================================
# En développement: http://localhost:3000,http://localhost:5173
# En production: https://akiprisaye.app,https://www.akiprisaye.app
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ========================================
# Logging
# ========================================
# Niveaux: error, warn, info, debug
LOG_LEVEL="info"

# ========================================
# RGPD & Conformité
# ========================================
# Responsable du traitement des données (DPO)
DATA_PROTECTION_OFFICER_EMAIL="dpo@akiprisaye.app"

# Durée de conservation des données (en jours)
DATA_RETENTION_DAYS="365"

# ========================================
# Rate Limiting
# ========================================
# Limite de requêtes par fenêtre de temps
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"   # 100 requêtes max

# ========================================
# Fonctionnalités optionnelles
# ========================================
# Activer/désactiver certaines fonctionnalités
ENABLE_SWAGGER="true"
ENABLE_METRICS="true"

# ========================================
# Stripe Payment Configuration
# ========================================
# Get your API keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Product IDs (create products in Stripe dashboard)
STRIPE_PRODUCT_CITIZEN_PREMIUM="prod_..."
STRIPE_PRODUCT_SME="prod_..."
STRIPE_PRODUCT_BUSINESS="prod_..."
STRIPE_PRODUCT_INSTITUTIONAL="prod_..."

# Stripe Price IDs (create prices in Stripe dashboard)
STRIPE_PRICE_CITIZEN_PREMIUM="price_..."
STRIPE_PRICE_SME="price_..."
STRIPE_PRICE_BUSINESS="price_..."
STRIPE_PRICE_INSTITUTIONAL="price_..."
