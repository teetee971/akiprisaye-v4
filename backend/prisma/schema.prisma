  longitude Decimal? @db.Decimal(11, 8)
  
  /// Date de vérification
  verifiedAt DateTime @default(now()) @map("verified_at")
  
  /// Fiabilité de la vérification (0-100%)
  verificationScore Int @default(100) @map("verification_score")
  
  /// Notes de vérification
  notes String? @db.Text
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@index([siren])
  @@index([siret])
  @@index([activityStatus])
  @@map("company_verifications")
}

/// Journal des accès aux sources de données externes
/// Traçabilité complète - audit obligatoire
/// RGPD: Art. 30 - Registre des activités de traitement
model SourceDataLog {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Source de données
  sourceId String @map("source_id")
  source ExternalDataSource @relation(fields: [sourceId], references: [id])
  
  /// Action effectuée
  /// Exemple: "SYNC", "QUERY", "VERIFICATION"
  action String @db.VarChar(100)
  
  /// Endpoint ou méthode appelée
  endpoint String? @db.VarChar(500)
  
  /// Résultat de l'action
  result DataActionResult
  
  /// Nombre d'enregistrements traités
  recordCount Int? @map("record_count")
  
  /// Temps de réponse (ms)
  responseTime Int? @map("response_time")
  
  /// Message d'erreur (si échec)
  errorMessage String? @map("error_message") @db.Text
  
  /// Utilisateur ayant initié l'action (si applicable)
  userId String? @map("user_id")
  
  /// Adresse IP
  ipAddress String? @map("ip_address") @db.VarChar(45)
  
  /// User agent
  userAgent String? @map("user_agent") @db.VarChar(500)
  
  /// Métadonnées supplémentaires (JSON)
  metadata String? @db.Text
  
  /// Date de l'action
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([sourceId])
  @@index([action])
  @@index([result])
  @@index([createdAt])
  @@map("source_data_logs")
}

// ============================================================
// ENUMS SPRINT 11
// ============================================================

/// Type de source de données externe
enum DataSourceType {
  INSEE              // Institut national de la statistique
  DGCCRF             // Direction générale de la concurrence
  RAPPEL_CONSO       // rappel.conso.gouv.fr
  COMPANY_REGISTRY   // Registres d'entreprises
  OPEN_DATA_PORTAL   // Portails open data
  API_GOUV           // api.gouv.fr
  OTHER              // Autres sources officielles
}

/// Gravité d'un rappel de produit
enum RecallSeverity {
  CRITICAL   // Danger immédiat pour la santé
  HIGH       // Risque important
  MEDIUM     // Risque modéré
  LOW        // Risque faible
  INFO       // Information préventive
}

/// Statut d'activité d'une entreprise
enum CompanyActivityStatus {
  ACTIVE     // Entreprise active
  CEASED     // Activité cessée
  SUSPENDED  // Activité suspendue
  UNKNOWN    // Statut inconnu
}

/// Résultat d'une action sur source externe
enum DataActionResult {
  SUCCESS    // Succès
  FAILURE    // Échec
  PARTIAL    // Succès partiel
  TIMEOUT    // Timeout
  UNAUTHORIZED // Non autorisé
}

// ============================================================
// SPRINT 13: OBSERVATOIRE PERMANENT DE LA VIE CHÈRE
// ============================================================

/// Rapport de l'Observatoire permanent
/// Analyse long terme de la vie chère
/// Immutable après publication (no deletion allowed)
/// 
/// Références légales:
/// - Neutralité absolue (pas de recommandations commerciales)
/// - Méthodologie transparente
/// - Données réelles uniquement
model ObservatoryReport {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Titre du rapport
  title String @db.VarChar(500)
  
  /// Périmètre du rapport
  scope ReportScope
  
  /// Territoire concerné (si scope TERRITORIAL)
  territory Territory?
  
  /// Catégorie de produits (si scope SECTORIEL)
  category String? @db.VarChar(255)
  
  /// Début de la période analysée
  periodStart DateTime @map("period_start")
  
  /// Fin de la période analysée
  periodEnd DateTime @map("period_end")
  
  /// Méthodologie utilisée
  /// Description claire et transparente
  methodology String @db.Text
  
  /// Principales conclusions
  keyFindings String @map("key_findings") @db.Text
  
  /// Limites de l'analyse
  /// Transparence obligatoire
  limitations String @db.Text
  
  /// Auteur du rapport
  /// Pour traçabilité institutionnelle
  author String @db.VarChar(255)
  
  /// Date de génération du rapport
  generatedAt DateTime @default(now()) @map("generated_at")
  
  /// Date de publication officielle
  /// Null si DRAFT
  publishedAt DateTime? @map("published_at")
  
  /// Statut du rapport
  status ReportStatus @default(DRAFT)
  
  /// Relations
  indicators StructuralIndicator[]
  insights   ExplanatoryInsight[]
  
  @@index([scope])
  @@index([territory])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([status])
  @@index([publishedAt])
  @@map("observatory_reports")
}

/// Indicateur structurel de la vie chère
/// Calculé à partir de données historiques uniquement
/// 
/// Indicateurs disponibles:
/// - DISPERSION_PRIX: Coefficient de variation des prix
/// - VOLATILITE: Écart-type des variations
/// - ECART_METROPOLE: Différence avec prix métropole
/// - TENSION_MARCHE: Ratio offre/demande estimé
/// - PERSISTENCE_HAUSSE: Durée des hausses continues
model StructuralIndicator {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Rapport associé (optionnel)
  reportId String? @map("report_id")
  report   ObservatoryReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  
  /// Type d'indicateur
  indicatorType IndicatorType @map("indicator_type")
  
  /// Territoire concerné
  territory Territory
  
  /// Catégorie de produits
  /// Null = tous produits
  category String? @db.VarChar(255)
  
  /// Valeur de l'indicateur
  /// Interprétation dépend du type
  value Decimal @db.Decimal(10, 4)
  
  /// Niveau de confiance (0-1)
  /// Basé sur quantité de données
  confidenceLevel Decimal @map("confidence_level") @db.Decimal(3, 2)
  
  /// Période de référence
  /// Format: "YYYY-MM" ou "YYYY-Q1", etc.
  period String @db.VarChar(50)
  
  /// Date de calcul de l'indicateur
  calculatedAt DateTime @default(now()) @map("calculated_at")
  
  /// Relations
  insights ExplanatoryInsight[]
  
  @@index([indicatorType])
  @@index([territory])
  @@index([category])
  @@index([period])
  @@index([calculatedAt])
  @@map("structural_indicators")
}

/// Analyse IA explicative (NON prédictive)
/// L'IA explique le passé, elle ne prédit rien
/// Toutes les analyses sont revues par un humain
/// 
/// Références légales:
/// - RGPD Art. 22: Pas de décision automatisée
/// - Transparence algorithmique obligatoire
/// - Sources visibles
model ExplanatoryInsight {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Rapport associé (optionnel)
  reportId String? @map("report_id")
  report   ObservatoryReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  
  /// Indicateur associé (optionnel)
  indicatorId String? @map("indicator_id")
  indicator   StructuralIndicator? @relation(fields: [indicatorId], references: [id], onDelete: SetNull)
  
  /// Explication textuelle claire
  /// Langage accessible au grand public
  explanation String @db.Text
  
  /// Sources utilisées pour l'analyse
  /// JSON array: [{"name": "INSEE", "date": "2025-01"}]
  sources String @db.Text
  
  /// Score de confiance de l'analyse (0-1)
  /// Basé sur cohérence des données
  confidenceScore Decimal @map("confidence_score") @db.Decimal(3, 2)
  
  /// Version du modèle IA utilisé
  /// Pour traçabilité et reproductibilité
  modelVersion String @map("model_version") @db.VarChar(50)
  
  /// Date de génération de l'analyse
  generatedAt DateTime @default(now()) @map("generated_at")
  
  /// Revue par un humain (obligatoire avant publication)
  reviewedByHuman Boolean @default(false) @map("reviewed_by_human")
  
  /// Nom du reviewer (si reviewedByHuman = true)
  reviewedBy String? @map("reviewed_by") @db.VarChar(255)
  
  /// Date de la revue humaine
  reviewedAt DateTime? @map("reviewed_at")
  
  /// Commentaires du reviewer
  reviewComments String? @map("review_comments") @db.Text
  
  @@index([reportId])
  @@index([indicatorId])
  @@index([reviewedByHuman])
  @@index([generatedAt])
  @@map("explanatory_insights")
}

// ============================================================
// ENUMS SPRINT 13
// ============================================================

/// Périmètre d'un rapport d'observatoire
enum ReportScope {
  NATIONAL     // Analyse nationale globale
  TERRITORIAL  // Analyse d'un territoire spécifique
  SECTORIEL    // Analyse d'un secteur/catégorie
}

/// Type d'indicateur structurel
enum IndicatorType {
  DISPERSION_PRIX    // Coefficient de variation des prix
  VOLATILITE         // Écart-type des variations de prix
  ECART_METROPOLE    // Différence avec prix métropole
  TENSION_MARCHE     // Ratio offre/demande estimé
  PERSISTENCE_HAUSSE // Durée moyenne des hausses continues
}

/// Statut d'un rapport d'observatoire
enum ReportStatus {
  DRAFT      // Brouillon (en cours de rédaction)
  PUBLISHED  // Publié officiellement (immutable)
  ARCHIVED   // Archivé (historique)
}

// ============================================================
// SPRINT 14: IA EXPLICATIVE MULTI-SOURCES CERTIFIÉE
// ============================================================

/// Cadre de recherche IA scientifique
/// Documentation niveau publication scientifique
/// Reproductibilité et auditabilité garanties
/// 
/// Références légales:
/// - Transparence algorithmique (Conseil d'État)
/// - IA responsable (RGPD Art. 22)
/// - Compatible recherche publique
model AIResearchFramework {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Nom du framework/modèle
  name String @unique @db.VarChar(255)
  
  /// Objectif scientifique clair
  /// Ex: "Expliquer variations prix alimentaires DOM"
  objective String @db.Text
  
  /// Sources de données utilisées (JSON array)
  /// [{name, type, coverage, period}]
  dataSources String @map("data_sources") @db.Text
  
  /// Méthodes statistiques/ML utilisées
  /// Description niveau publication
  methods String @db.Text
  
  /// Hypothèses du modèle
  /// Explicitation claire
  assumptions String @db.Text
  
  /// Biais connus et documentés
  /// Transparence obligatoire
  knownBiases String @map("known_biases") @db.Text
  
  /// Limitations méthodologiques
  /// Cas où le modèle n'est pas applicable
  limitations String @db.Text
  
  /// Version du framework (semver)
  version String @db.VarChar(50)
  
  /// Créé le
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Validé par (expert scientifique)
  /// Null si pas encore validé
  validatedBy String? @map("validated_by") @db.VarChar(255)
  
  /// Date de validation
  validatedAt DateTime? @map("validated_at")
  
  /// Commentaires validation
  validationComments String? @map("validation_comments") @db.Text
  
  /// Relations
  explanations ExplanationResult[]
  computations ComputationTrace[]
  reviews      HumanReview[]
  
  @@index([name])
  @@index([version])
  @@index([validatedBy])
  @@map("ai_research_frameworks")
}

/// Registre des sources de données
/// Traçabilité complète des inputs IA
/// 
/// Chaque source doit être:
/// - Officiellement autorisée (lecture seule)
/// - Licence compatible
/// - Fiabilité documentée
model DataSourceRegistry {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Nom de la source
  /// Ex: "A KI PRI SA YÉ - Prix historiques"
  name String @db.VarChar(500)
  
  /// Type de source
  type DataSourceType
  
  /// Licence d'utilisation
  /// Ex: "Licence Ouverte v2.0"
  licence String @db.VarChar(255)
  
  /// Fréquence de mise à jour
  updateFrequency UpdateFrequency @map("update_frequency")
  
  /// Score de fiabilité (0-100)
  /// Basé sur: complétude, cohérence, vérifications
  reliabilityScore Int @map("reliability_score") @db.SmallInt
  
  /// Périmètre couvert (JSON)
  /// {territories, categories, period}
  coverage String @db.Text
  
  /// URL source officielle
  sourceUrl String? @map("source_url") @db.VarChar(1000)
  
  /// Description
  description String? @db.Text
  
  /// Date d'ajout au registre
  registeredAt DateTime @default(now()) @map("registered_at")
  
  /// Dernière vérification fiabilité
  lastVerified DateTime? @map("last_verified")
  
  /// Statut (actif/deprecated)
  isActive Boolean @default(true) @map("is_active")
  
  /// Relations
  explanations ExplanationResult[]
  
  @@index([type])
  @@index([reliabilityScore])
  @@index([isActive])
  @@map("data_source_registry")
}

/// Résultat d'explication IA
/// Explication = décomposition facteurs passés
/// NON prédictif, NON prescriptif
/// 
/// Références légales:
/// - Pas de conseil économique
/// - Pas de décision automatisée
/// - Transparence méthodologique totale
model ExplanationResult {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Framework IA utilisé
  frameworkId String @map("framework_id")
  framework   AIResearchFramework @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  
  /// Indicateur analysé (optionnel)
  indicatorId String? @map("indicator_id")
  indicator   StructuralIndicator? @relation(fields: [indicatorId], references: [id], onDelete: SetNull)
  
  /// Facteurs identifiés (JSON array)
  /// [{name, contribution, confidence, sources}]
  /// Ex: [{"name": "Distance géo", "contribution": 0.42, ...}]
  factors String @db.Text
  
  /// Poids de chaque facteur (JSON)
  /// Somme = 1.0 (100%)
  weights String @db.Text
  
  /// Intervalle de confiance (JSON)
  /// {lower: 0.85, upper: 0.95}
  confidenceInterval String @map("confidence_interval") @db.Text
  
  /// Méthode d'explication utilisée
  methodUsed ExplanationMethod @map("method_used")
  
  /// Sources de données utilisées (relation)
  sourceIds String @map("source_ids") @db.Text // JSON array d'IDs
  sources   DataSourceRegistry[]
  
  /// Explication textuelle générée
  /// Langage accessible
  textExplanation String? @map("text_explanation") @db.Text
  
  /// Date de génération
  generatedAt DateTime @default(now()) @map("generated_at")
  
  /// Hash computation associé (reproductibilité)
  computationTraceId String? @map("computation_trace_id")
  computationTrace   ComputationTrace? @relation(fields: [computationTraceId], references: [id], onDelete: SetNull)
  
  /// Revue humaine associée
  humanReviewId String? @map("human_review_id")
  humanReview   HumanReview? @relation(fields: [humanReviewId], references: [id], onDelete: SetNull)
  
  /// Statut publication
  isPublished Boolean @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  
  @@index([frameworkId])
  @@index([indicatorId])
  @@index([methodUsed])
  @@index([isPublished])
  @@index([generatedAt])
  @@map("explanation_results")
}

/// Trace de calcul pour reproductibilité
/// Garantit auditabilité scientifique
/// 
/// Permet de re-exécuter exactement le même calcul
/// avec les mêmes résultats (déterminisme)
model ComputationTrace {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Framework IA utilisé
  frameworkId String @map("framework_id")
  framework   AIResearchFramework @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  
  /// Hash des inputs (SHA-256)
  /// Données entrée + paramètres
  inputsHash String @map("inputs_hash") @db.VarChar(64)
  
  /// Inputs détaillés (JSON)
  /// Pour reproductibilité exacte
  inputsDetail String @map("inputs_detail") @db.Text
  
  /// Version algorithme utilisée
  algorithmVersion String @map("algorithm_version") @db.VarChar(50)
  
  /// Hash du résultat (SHA-256)
  /// Permet vérification intégrité
  outputHash String @map("output_hash") @db.VarChar(64)
  
  /// Résultat détaillé (JSON)
  outputDetail String @map("output_detail") @db.Text
  
  /// Temps d'exécution (ms)
  executionTime Int @map("execution_time")
  
  /// Date/heure exécution (UTC)
  executedAt DateTime @default(now()) @map("executed_at")
  
  /// Environnement exécution (JSON)
  /// {os, node_version, dependencies}
  environment String? @db.Text
  
  /// Reproductible (déterministe)
  isReproducible Boolean @default(true) @map("is_reproducible")
  
  /// Relations
  explanations ExplanationResult[]
  
  @@index([frameworkId])
  @@index([inputsHash])
  @@index([executedAt])
  @@map("computation_traces")
}

/// Revue humaine des résultats IA
/// Validation obligatoire avant publication
/// 
/// Workflow:
/// 1. IA génère explication
/// 2. Expert humain revoit
/// 3. Décision: APPROVED / REJECTED / NEEDS_REVISION
/// 4. Si APPROVED → Publication
model HumanReview {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Framework IA revu
  frameworkId String? @map("framework_id")
  framework   AIResearchFramework? @relation(fields: [frameworkId], references: [id], onDelete: SetNull)
  
  /// Explication revue (optionnel)
  explanationId String? @map("explanation_id")
  explanation   ExplanationResult? @relation(fields: [explanationId], references: [id], onDelete: SetNull)
  
  /// Nom/ID du reviewer
  /// Expert scientifique qualifié
  reviewer String @db.VarChar(255)
  
  /// Qualifications reviewer
  /// Ex: "Dr. en Économie, 15 ans exp. analyse prix"
  reviewerCredentials String? @map("reviewer_credentials") @db.Text
  
  /// Date de la revue
  reviewedAt DateTime @default(now()) @map("reviewed_at")
  
  /// Décision
  decision ReviewDecision
  
  /// Commentaires détaillés
  /// Justification de la décision
  comments String @db.Text
  
  /// Modifications suggérées (si NEEDS_REVISION)
  suggestedChanges String? @map("suggested_changes") @db.Text
  
  /// Score qualité (0-10)
  /// Évaluation globale par reviewer
  qualityScore Int? @map("quality_score") @db.SmallInt
  
  /// Critères évaluation (JSON)
  /// {accuracy, clarity, completeness, methodology}
  evaluationCriteria String? @map("evaluation_criteria") @db.Text
  
  @@index([frameworkId])
  @@index([explanationId])
  @@index([reviewer])
  @@index([decision])
  @@index([reviewedAt])
  @@map("human_reviews")
}

// ============================================================
// ENUMS SPRINT 14
// ============================================================

/// Méthode d'explication IA
enum ExplanationMethod {
  DECOMPOSITION_FACTORS  // Décomposition en facteurs contributifs
  CORRELATION_ANALYSIS   // Analyse de corrélation documentée
  CONTRIBUTION_WEIGHTS   // Contribution pondérée par facteur
  TEMPORAL_COMPARISON    // Comparaison temporelle contrôlée
  TERRITORIAL_EFFECTS    // Effets territoriaux persistants
  REGRESSION_BASED       // Basée sur régression linéaire/non-linéaire
  ENSEMBLE_METHODS       // Combinaison plusieurs méthodes
}

/// Décision revue humaine
enum ReviewDecision {
  APPROVED         // Approuvé pour publication
  REJECTED         // Rejeté (méthodologie incorrecte)
  NEEDS_REVISION   // Nécessite modifications
  PENDING          // En attente de revue
}

// ============================================================
// CITIZEN CHAT BACKEND (Backend-only, no frontend)
// ============================================================
// Private citizen discussion groups for cost of living topics
// - JWT authentication required
// - Verified users only
// - AI-assisted moderation (non-blocking, passive)
// - RGPD compliant (data minimization, audit trail)
// - Territory-based groups (DOM, COM, ROM, RUP)
// 
// Frontend implementation planned separately
// WebSocket client implementation planned separately
// ============================================================

/// Verified user profile for chat system
/// Extended profile for chat participation
/// 
/// RGPD: Art. 5 (data minimization), Art. 6 (lawful basis)
/// Only verified users can participate in discussions
model ChatUserProfile {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Lien vers User principal (JWT auth)
  /// CASCADE: suppression profil si user supprimé
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  /// Pseudonyme public affiché dans les groupes
  /// RGPD: Pseudonymisation (Art. 4.5)
  displayName String @map("display_name") @db.VarChar(100)
  
  /// URL avatar (photo de profil - facultative)
  /// Stockage S3-compatible recommandé
  /// RGPD: Consentement explicite requis pour photo
  avatarUrl String? @map("avatar_url") @db.VarChar(500)
  
  /// Code territoire (COG INSEE)
  /// Ex: "971" (Guadeloupe), "972" (Martinique), "973" (Guyane)
  /// Permet groupes territoriaux et affichage drapeau
  territoryCode String @map("territory_code") @db.VarChar(10)
  
  /// Région/ville (optionnel, pour contexte)
  /// Ex: "Pointe-à-Pitre", "Fort-de-France"
  location String? @db.VarChar(100)
  
  /// Statut utilisateur chat
  /// VERIFIED: Peut participer
  /// MUTED: Temporairement silencieux (sanction modération)
  /// SUSPENDED: Suspendu définitivement
  status ChatUserStatus @default(VERIFIED)
  
  /// Date fin mute (si MUTED)
  /// NULL si statut != MUTED
  mutedUntil DateTime? @map("muted_until")
  
  /// Biographie courte (optionnelle)
  /// Max 500 chars, modérable
  bio String? @db.VarChar(500)
  
  /// Préférences notifications (JSON)
  /// {mention: true, newMessage: false, dailyDigest: true}
  notificationPreferences String? @map("notification_preferences") @db.Text
  
  /// Date création profil
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date dernière mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  /// Messages envoyés
  messages ChatMessage[]
  
  /// Appartenance groupes
  memberships ChatGroupMembership[]
  
  /// Actions de modération reçues
  moderationActions ChatModerationAction[]
  
  @@index([userId])
  @@index([territoryCode])
  @@index([status])
  @@index([displayName])
  @@map("chat_user_profiles")
}

/// Discussion group (groupe de parole)
/// Groupes privés organisés par territoire ou thématique
/// 
/// Types:
/// - Territoriaux: Par DOM/COM/ROM (code INSEE)
/// - Thématiques: Alimentation, carburant, logement
/// - Situations: Familles, étudiants, retraités
model ChatGroup {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Nom du groupe
  /// Ex: "Vie chère Guadeloupe", "Carburant Martinique"
  name String @db.VarChar(150)
  
  /// Description groupe
  description String @db.Text
  
  /// Type de groupe
  groupType ChatGroupType @map("group_type")
  
  /// Code territoire associé (si type TERRITORIAL)
  /// Code INSEE: "971", "972", "973", etc.
  /// NULL si type THEMATIC ou SITUATION
  territoryCode String? @map("territory_code") @db.VarChar(10)
  
  /// Thématique (si type THEMATIC)
  /// Ex: FOOD, FUEL, HOUSING
  theme ChatTheme?
  
  /// Icône groupe (emoji ou URL)
  /// Ex: "🛒" pour alimentation, "⛽" pour carburant
  icon String? @db.VarChar(100)
  
  /// Métadonnées groupe (JSON)
  /// {flagCode: "GP", color: "#003580", rules: [...]}
  metadata String? @db.Text
  
  /// Règles du groupe
  /// Texte affiché aux nouveaux membres
  rules String @db.Text
  
  /// Groupe actif ou archivé
  isActive Boolean @default(true) @map("is_active")
  
  /// Nombre maximum de membres (optionnel)
  /// NULL = illimité
  maxMembers Int? @map("max_members") @db.Integer
  
  /// Date création groupe
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date dernière activité (dernier message)
  lastActivityAt DateTime? @map("last_activity_at")
  
  /// Messages du groupe
  messages ChatMessage[]
  
  /// Membres du groupe
  memberships ChatGroupMembership[]
  
  @@index([groupType])
  @@index([territoryCode])
  @@index([theme])
  @@index([isActive])
  @@index([lastActivityAt])
  @@map("chat_groups")
}

/// Membership in discussion group
/// Association user ↔ group avec métadonnées
model ChatGroupMembership {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Profil utilisateur
  userProfileId String @map("user_profile_id")
  userProfile   ChatUserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  
  /// Groupe
  groupId String @map("group_id")
  group   ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  /// Rôle dans le groupe
  /// MEMBER: Membre standard
  /// MODERATOR: Modérateur groupe (peut signaler)
  /// ADMIN: Administrateur groupe (peut gérer membres)
  role ChatGroupRole @default(MEMBER)
  
  /// Date adhésion
  joinedAt DateTime @default(now()) @map("joined_at")
  
  /// Date dernière lecture (pour notifications)
  /// Permet calcul messages non lus
  lastReadAt DateTime? @map("last_read_at")
  
  /// Notifications activées pour ce groupe
  notificationsEnabled Boolean @default(true) @map("notifications_enabled")
  
  @@unique([userProfileId, groupId])
  @@index([userProfileId])
  @@index([groupId])
  @@index([role])
  @@map("chat_group_memberships")
}

/// Chat message
/// Messages échangés dans groupes de discussion
/// 
/// RGPD: Art. 30 (registre), Art. 17 (droit à l'effacement)
/// Modération: IA passive + signalement humain
model ChatMessage {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Auteur du message
  authorId String @map("author_id")
  author   ChatUserProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  /// Groupe de discussion
  groupId String @map("group_id")
  group   ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  /// Contenu texte du message
  /// Max 2000 caractères recommandé
  content String @db.Text
  
  /// Type de message
  messageType ChatMessageType @default(TEXT) @map("message_type")
  
  /// URL pièce jointe (optionnel)
  /// Photo, document (pas implémenté initialement)
  /// Stockage S3-compatible recommandé
  attachmentUrl String? @map("attachment_url") @db.VarChar(500)
  
  /// Métadonnées pièce jointe (JSON)
  /// {fileName: "...", mimeType: "...", size: 123456}
  attachmentMetadata String? @map("attachment_metadata") @db.Text
  
  /// Message en réponse à (threading)
  /// NULL si message racine
  replyToId String? @map("reply_to_id")
  replyTo   ChatMessage? @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  
  /// Réponses à ce message
  replies ChatMessage[] @relation("MessageReplies")
  
  /// Statut modération IA
  moderationStatus ChatModerationStatus @default(PENDING) @map("moderation_status")
  
  /// Score toxicité IA (0.0 - 1.0)
  /// Détection automatique propos haineux/agressifs
  /// NULL si pas encore analysé
  toxicityScore Float? @map("toxicity_score") @db.Real
  
  /// Flags modération IA (JSON array)
  /// ["profanity", "aggression", "spam"]
  /// NULL si aucun flag
  moderationFlags String? @map("moderation_flags") @db.Text
  
  /// Message édité
  isEdited Boolean @default(false) @map("is_edited")
  
  /// Date dernière édition
  editedAt DateTime? @map("edited_at")
  
  /// Message supprimé par auteur
  /// Soft delete: conservé pour audit mais masqué
  isDeleted Boolean @default(false) @map("is_deleted")
  
  /// Date suppression
  deletedAt DateTime? @map("deleted_at")
  
  /// Date création (horodatage)
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Actions modération sur ce message
  moderationActions ChatModerationAction[]
  
  @@index([authorId])
  @@index([groupId])
  @@index([replyToId])
  @@index([moderationStatus])
  @@index([isDeleted])
  @@index([createdAt])
  @@map("chat_messages")
}

/// Moderation action log
/// Journal actions modération (IA + humaine)
/// 
/// RGPD: Art. 30 (registre activités de traitement)
/// Traçabilité complète pour transparence et contestation
model ChatModerationAction {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Message concerné
  messageId String @map("message_id")
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  /// Utilisateur ciblé (auteur message ou profil)
  targetUserId String @map("target_user_id")
  targetUser   ChatUserProfile @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  
  /// Type d'action modération
  actionType ChatModerationType @map("action_type")
  
  /// Source action
  /// AI: Détection automatique IA
  /// USER_REPORT: Signalement utilisateur
  /// MODERATOR: Action modérateur humain
  /// ADMIN: Action administrateur
  source ChatModerationSource
  
  /// ID modérateur humain (si source = MODERATOR/ADMIN)
  /// Lien vers User.id (compte admin)
  moderatorId String? @map("moderator_id")
  
  /// Raison détaillée
  /// Justification action pour transparence
  reason String @db.Text
  
  /// Durée sanction (minutes)
  /// Pour MUTE: durée mute
  /// NULL pour autres actions
  durationMinutes Int? @map("duration_minutes") @db.Integer
  
  /// Action révoquée/annulée
  isRevoked Boolean @default(false) @map("is_revoked")
  
  /// Date révocation
  revokedAt DateTime? @map("revoked_at")
  
  /// Raison révocation
  revocationReason String? @map("revocation_reason") @db.Text
  
  /// Date action
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([messageId])
  @@index([targetUserId])
  @@index([actionType])
  @@index([source])
  @@index([moderatorId])
  @@index([createdAt])
  @@map("chat_moderation_actions")
}

/// AI moderation model metadata
/// Métadonnées modèle IA modération
/// Traçabilité versions modèle pour reproductibilité
model ChatModerationModel {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Nom modèle
  /// Ex: "toxicity-detector-v1", "hate-speech-classifier-v2"
  name String @db.VarChar(100)
  
  /// Version modèle
  /// Semantic versioning: "1.0.0", "2.1.3"
  version String @db.VarChar(20)
  
  /// Type modèle
  modelType ChatModerationModelType @map("model_type")
  
  /// Provider/source
  /// Ex: "OpenAI Moderation API", "Hugging Face transformers", "Internal ML"
  provider String @db.VarChar(100)
  
  /// Configuration modèle (JSON)
  /// {thresholds: {toxicity: 0.7, spam: 0.8}, languages: ["fr"]}
  config String? @db.Text
  
  /// Statistiques performance (JSON)
  /// {accuracy: 0.92, precision: 0.89, recall: 0.85, f1: 0.87}
  performanceMetrics String? @map("performance_metrics") @db.Text
  
  /// Modèle actif (utilisé en production)
  isActive Boolean @default(false) @map("is_active")
  
  /// Date déploiement
  deployedAt DateTime? @map("deployed_at")
  
  /// Date création
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([name])
  @@index([version])
  @@index([isActive])
  @@map("chat_moderation_models")
}

// ============================================================
// CHAT ENUMS
// ============================================================

/// Statut utilisateur chat
enum ChatUserStatus {
  VERIFIED   // Vérifié, peut participer
  MUTED      // Temporairement silencieux (sanction)
  SUSPENDED  // Suspendu définitivement
}

