generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ===============================
/// ENUMS
/// ===============================
enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  INSTITUTION
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  EXPIRED
}

enum PriceInterval {
  MONTH
  YEAR
}

enum UserRole {
  USER
  ADMIN
  INSTITUTION
}

enum AlertType {
  PRICE_DROP
  PRICE_TARGET
  PROMOTION
  PRICE_INCREASE
  BACK_IN_STOCK
  NEW_STORE
  BEST_PRICE
}

enum NotificationType {
  ALERT_TRIGGERED
  WEEKLY_DIGEST
  SYSTEM
  WELCOME
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum DigestFrequency {
  DAILY
  WEEKLY
  MONTHLY
  NEVER
}

enum PointAction {
  SUBMIT_PRICE
  PRICE_VALIDATED
  ADD_PRODUCT
  REPORT_STORE
  VERIFY_PRICE
  STREAK_BONUS
  REFERRAL
  CHALLENGE_COMPLETED
  BADGE_UNLOCKED
  LEVEL_UP
}

enum BadgeCategory {
  CONTRIBUTION
  STREAK
  SOCIAL
  TERRITORY
  SPECIAL
}

enum BadgeRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ChallengeType {
  DAILY
  WEEKLY
  MONTHLY
  SPECIAL
}

/// Verified Pricing System Enums
enum PriceSource {
  USER_SUBMISSION
  STORE_OFFICIAL
  RECEIPT_SCAN
  API_INTEGRATION
  COMMUNITY_VERIFIED
  ADMIN_OVERRIDE
}

enum VerificationStatus {
  PENDING
  CONFIRMED
  DISPUTED
  REJECTED
  EXPIRED
enum ProductSource {
  MANUAL
  OCR
  OPENFOODFACTS
  OPENPRICES
  CITIZEN
}

enum ProductStatus {
  PENDING_REVIEW
  VALIDATED
  REJECTED
  MERGED
}

enum PriceSource {
  OCR_TICKET
  OFFICIAL_API
  OPEN_PRICES
  MANUAL_ENTRY
  CROWDSOURCED
  SCRAPING_AUTHORIZED
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  DISPUTED
}

enum VerificationAction {
  CONFIRM
  DISPUTE
  UPDATE
}

enum AnomalyType {
  SUDDEN_INCREASE
  SUDDEN_DECREASE
  OUTLIER_HIGH
  OUTLIER_LOW
  SHRINKFLATION
  INCONSISTENT_REPORT
  STALE_DATA
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

/// ===============================
/// MODELS
/// ===============================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)

  subscription           Subscription?
  priceAlerts            PriceAlert[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  gamification           UserGamification?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  plan        SubscriptionPlan
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  externalRef String? /// (option Stripe, extensible plus tard)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Price {
  id          String           @id @default(cuid())
  plan        SubscriptionPlan
  interval    PriceInterval
  amountCents Int /// Stocké en centimes (990 = 9.90€)
  currency    String           @default("EUR")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([plan, interval])
}

/// ===============================
/// PRICE ALERT MODELS
/// ===============================

model PriceAlert {
  id        String @id @default(cuid())
  userId    String
  productId String

  alertType           AlertType
  targetPrice         Float?
  percentageThreshold Float?

  storeIds  String[] @default([])
  territory String?
  chains    String[] @default([])

  notifyEmail Boolean @default(true)
  notifyPush  Boolean @default(true)
  notifySms   Boolean @default(false)

  isActive        Boolean   @default(true)
  triggeredCount  Int       @default(0)
  lastTriggeredAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([userId])
  @@index([productId])
  @@index([isActive])
}

model Notification {
  id      String  @id @default(cuid())
  userId  String
  alertId String?

  type    NotificationType
  channel NotificationChannel

  title String
  body  String
  data  Json?

  status        NotificationStatus @default(PENDING)
  sentAt        DateTime?
  readAt        DateTime?
  failedAt      DateTime?
  failureReason String?

  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert PriceAlert? @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PushSubscription {
  id        String  @id @default(cuid())
  userId    String
  endpoint  String  @unique
  p256dh    String
  auth      String
  userAgent String?

  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique

  emailEnabled Boolean @default(true)
  pushEnabled  Boolean @default(true)
  smsEnabled   Boolean @default(false)

  emailAddress String?
  phoneNumber  String?

  digestFrequency DigestFrequency @default(WEEKLY)
  quietHoursStart String?
  quietHoursEnd   String?
  timezone        String          @default("America/Guadeloupe")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// ===============================
/// GAMIFICATION MODELS
/// ===============================

model UserGamification {
  id     String @id @default(cuid())
  userId String @unique

  totalXP      Int @default(0)
  currentLevel Int @default(1)

  // Streak
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActivityAt  DateTime?
  streakStartedAt DateTime?

  // Stats
  pricesSubmitted   Int @default(0)
  pricesVerified    Int @default(0)
  productsAdded     Int @default(0)
  storesVisited     Int @default(0)
  anomaliesReported Int @default(0)
  referralsCount    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  badges        UserBadge[]
  pointsHistory PointsTransaction[]
  challenges    UserChallenge[]

  @@index([totalXP])
  @@index([currentLevel])
  @@index([userId])
}

model PointsTransaction {
  id String @id @default(cuid())

  userGamificationId String
  action             PointAction
  points             Int
  bonusPoints        Int         @default(0)
  reason             String
  metadata           Json?

  createdAt DateTime @default(now())

  userGamification UserGamification @relation(fields: [userGamificationId], references: [id], onDelete: Cascade)

  @@index([userGamificationId])
  @@index([createdAt])
}

model Badge {
  id             String        @id
  name           String
  description    String
  icon           String
  category       BadgeCategory
  rarity         BadgeRarity
  xpReward       Int
  conditionType  String
  conditionValue Json

  createdAt DateTime @default(now())

  users UserBadge[]

  @@index([category])
  @@index([rarity])
}

model UserBadge {
  id String @id @default(cuid())

  userGamificationId String
  badgeId            String
  unlockedAt         DateTime @default(now())

  userGamification UserGamification @relation(fields: [userGamificationId], references: [id], onDelete: Cascade)
  badge            Badge            @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userGamificationId, badgeId])
  @@index([userGamificationId])
  @@index([badgeId])
}

model Challenge {
  id             String        @id @default(cuid())
  name           String
  description    String
  icon           String
  type           ChallengeType
  conditionType  String
  conditionValue Int
  xpReward       Int
  badgeReward    String?
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean       @default(true)

  createdAt DateTime @default(now())

  users UserChallenge[]

  @@index([type])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model UserChallenge {
  id String @id @default(cuid())

  userGamificationId String
  challengeId        String
  progress           Int       @default(0)
  isCompleted        Boolean   @default(false)
  completedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userGamification UserGamification @relation(fields: [userGamificationId], references: [id], onDelete: Cascade)
  challenge        Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userGamificationId, challengeId])
  @@index([userGamificationId])
  @@index([challengeId])
  @@index([isCompleted])
}

/// ===============================
/// INFLATION DASHBOARD MODELS
/// ===============================

/// Price index by territory and month (base 100 = January 2024)
model PriceIndex {
  id            String @id @default(cuid())
  territory     String /// Territory code (GP, MQ, GF, RE, YT)
  year          Int
  month         Int
  indexValue    Float /// Price index (base 100)
  inflationRate Float /// Year-over-year inflation rate (%)
  monthlyChange Float /// Month-over-month change (%)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([territory, year, month])
  @@index([territory])
  @@index([year, month])
}

/// Category-level price indices
model CategoryIndex {
  id           String @id @default(cuid())
  territory    String /// Territory code (GP, MQ, GF, RE, YT)
  category     String /// Category: dairy, meat, bread, grocery, fruits_vegetables, beverages, hygiene
  year         Int
  month        Int
  indexValue   Float /// Category price index
  weight       Float /// Category weight in reference basket (%)
  contribution Float /// Contribution to overall inflation (%)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([territory, category, year, month])
  @@index([territory, year, month])
  @@index([category])
}

/// Monthly inflation reports with metadata
model InflationReport {
  id        String @id @default(cuid())
  territory String /// Territory code (GP, MQ, GF, RE, YT)
  year      Int
  month     Int

  reportData  Json /// Complete report data (metrics, trends, top movers)
  pressKitUrl String? /// URL to press kit PDF/XLSX

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([territory, year, month])
  @@index([territory])
  @@index([year, month])
  @@index([generatedAt])
}

/// Metropolitan France reference prices for comparison
model MetroReferencePrice {
  id           String @id @default(cuid())
  productCode  String /// Product code from reference basket
  year         Int
  month        Int
  averagePrice Float /// Average price in France métropolitaine (EUR)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productCode, year, month])
  @@index([productCode])
  @@index([year, month])
}

/// ===============================
/// PRODUCT SYNC MODELS
/// ===============================

model Product {
  id              String        @id @default(cuid())
  ean             String?       @unique
  name            String
  normalizedName  String
  brand           String?
  category        String?
  quantity        String?
  imageUrl        String?
  nutriscoreGrade String?
  ecoscoreGrade   String?
  source          ProductSource
  status          ProductStatus @default(PENDING_REVIEW)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  validatedAt     DateTime?
  validatedBy     String?

  prices  ProductPrice[]
  updates ProductUpdate[]

  @@index([normalizedName])
  @@index([status])
  @@index([ean])
}

model SyncLog {
  id             String    @id @default(cuid())
  source         String
  startedAt      DateTime
  completedAt    DateTime?
  status         String
  itemsProcessed Int       @default(0)
  itemsCreated   Int       @default(0)
  itemsUpdated   Int       @default(0)
  itemsSkipped   Int       @default(0)
  errors         Json?

  @@index([source])
  @@index([startedAt])
}

/// ===============================
/// VERIFIED PRICING MODELS
/// ===============================

/// Product Price Observation (Prix produit)
model ProductPrice {
  id        String @id @default(cuid())
  productId String
  storeId   String
  price     Float
  currency  String @default("EUR")

  // Traçabilité
  source     PriceSource
  observedAt DateTime
  reportedBy String?
  proofUrl   String?

  // Vérification
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verificationCount  Int                @default(0)
  lastVerifiedAt     DateTime?

  // Confiance
  confidenceScore   Int   @default(0)
  confidenceFactors Json?

  // Métadonnées
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  verifications PriceVerification[]
  anomalies     PriceAnomaly[]

  @@index([productId])
  @@index([storeId])
  @@index([observedAt])
  @@index([confidenceScore])
  @@index([verificationStatus])
}

model PriceVerification {
  id        String             @id @default(cuid())
  priceId   String
  userId    String
  action    VerificationAction
  comment   String?
  createdAt DateTime           @default(now())

  price ProductPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

  @@index([priceId])
  @@index([userId])
}

model PriceAnomaly {
  id          String      @id @default(cuid())
  priceId     String
  productId   String
  storeId     String
  anomalyType AnomalyType
  severity    Severity

  reportedPrice Float
  expectedPrice Float
  deviation     Float

  status     AnomalyStatus @default(PENDING)
  resolvedAt DateTime?
  resolvedBy String?
  resolution String?
  context    Json?

  createdAt DateTime @default(now())

  price ProductPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([severity])
  @@index([productId])
  @@index([storeId])
}

model ProductUpdate {
  id           String       @id @default(cuid())
  productId    String
  field        String
  oldValue     String?
  newValue     String
  source       String
  autoApplied  Boolean      @default(false)
  reviewStatus ReviewStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([reviewStatus])
  @@index([createdAt])
}
