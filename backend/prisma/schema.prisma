generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ===============================
/// ENUMS
/// ===============================
enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  INSTITUTION
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  EXPIRED
}

enum PriceInterval {
  MONTH
  YEAR
}

enum UserRole {
  USER
  ADMIN
  INSTITUTION
}

enum PriceSource {
  OCR_TICKET
  OFFICIAL_API
  OPEN_PRICES
  MANUAL_ENTRY
  CROWDSOURCED
  SCRAPING_AUTHORIZED
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  DISPUTED
}

enum VerificationAction {
  CONFIRM
  DISPUTE
  UPDATE
}

enum AnomalyType {
  SUDDEN_INCREASE
  SUDDEN_DECREASE
  OUTLIER_HIGH
  OUTLIER_LOW
  SHRINKFLATION
  INCONSISTENT_REPORT
  STALE_DATA
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionTier {
  FREE
  CITIZEN_PREMIUM
  SME
  BUSINESS_PRO
  INSTITUTIONAL
}

enum ApiPermission {
  READ_PRICES
  WRITE_PRICES
  READ_STORES
  WRITE_STORES
  READ_PRODUCTS
  WRITE_PRODUCTS
  READ_COMPARATORS
  READ_ANALYTICS
  READ_TERRITORIES
  WRITE_CONTRIBUTIONS
  EXPORT_DATA
  ADMIN
}

enum Territory {
  FRANCE_HEXAGONALE
  GUADELOUPE
  MARTINIQUE
  GUYANE
  LA_REUNION
  MAYOTTE
  SAINT_MARTIN
  SAINT_BARTHELEMY
  SAINT_PIERRE_ET_MIQUELON
  WALLIS_ET_FUTUNA
  POLYNESIE_FRANCAISE
  NOUVELLE_CALEDONIE
}

enum PointAction {
  LEVEL_UP
  PRICE_REPORT
  PRICE_VERIFY
  PHOTO_UPLOAD
  RECEIPT_SCAN
  DAILY_LOGIN
  STREAK_BONUS
  REFERRAL
  CHALLENGE_COMPLETE
  BADGE_EARNED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationType {
  PRICE_ALERT
  BADGE_EARNED
  CHALLENGE_COMPLETE
  SYSTEM_MESSAGE
  WEEKLY_SUMMARY
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum AlertType {
  PRICE_DROP
  PRICE_INCREASE
  NEW_PRODUCT
  STOCK_ALERT
  PRICE_TARGET
  PROMOTION
  BACK_IN_STOCK
  BEST_PRICE
  NEW_STORE
}

enum BadgeCategory {
  CONTRIBUTOR
  EXPLORER
  EXPERT
  SOCIAL
  SPECIAL
}

enum BadgeRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum ChallengeType {
  DAILY
  WEEKLY
  MONTHLY
  SPECIAL
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum RequesterType {
  INDIVIDUAL
  BUSINESS
  INSTITUTION
}

enum ApiKeyStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

enum BrandStatus {
  ACTIVE
  INACTIVE
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  CEASED
}

enum AuditResult {
  SUCCESS
  FAILURE
  PARTIAL
  DENIED
}

/// ===============================
/// MODELS
/// ===============================
model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  passwordHash     String
  role             UserRole         @default(USER)
  isActive         Boolean          @default(true)
  subscriptionTier SubscriptionTier @default(FREE)
  lastLogin        DateTime?

  subscription       Subscription?
  priceVerifications PriceVerification[]
  refreshTokens      RefreshToken[]
  apiKeys            ApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  plan        SubscriptionPlan
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  externalRef String? /// (option Stripe, extensible plus tard)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Price {
  id          String           @id @default(cuid())
  plan        SubscriptionPlan
  interval    PriceInterval
  amountCents Int /// Stocké en centimes (990 = 9.90€)
  currency    String           @default("EUR")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([plan, interval])
}

/// Product Price Observation (Prix produit)
model ProductPrice {
  id        String @id @default(cuid())
  productId String
  storeId   String
  price     Float
  currency  String @default("EUR")

  // Traçabilité
  source     PriceSource
  observedAt DateTime
  reportedBy String?
  proofUrl   String?

  // Vérification
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verificationCount  Int                @default(0)
  lastVerifiedAt     DateTime?

  // Confiance
  confidenceScore   Int   @default(0)
  confidenceFactors Json?

  // Métadonnées
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  verifications PriceVerification[]
  anomalies     PriceAnomaly[]

  @@index([productId])
  @@index([storeId])
  @@index([observedAt])
  @@index([confidenceScore])
  @@index([verificationStatus])
}

model PriceVerification {
  id        String             @id @default(cuid())
  priceId   String
  userId    String
  action    VerificationAction
  comment   String?
  createdAt DateTime           @default(now())

  price ProductPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([priceId, userId])
  @@index([priceId])
  @@index([userId])
}

model PriceAnomaly {
  id          String      @id @default(cuid())
  priceId     String
  productId   String
  storeId     String
  anomalyType AnomalyType
  severity    Severity

  reportedPrice Float
  expectedPrice Float
  deviation     Float

  status     AnomalyStatus @default(PENDING)
  resolvedAt DateTime?
  resolvedBy String?
  resolution String?
  context    Json?

  createdAt DateTime @default(now())

  price ProductPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([severity])
  @@index([productId])
  @@index([storeId])
}

model ProductUpdate {
  id           String       @id @default(cuid())
  productId    String
  field        String
  oldValue     String?
  newValue     String
  source       String
  autoApplied  Boolean      @default(false)
  reviewStatus ReviewStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())

  @@index([productId])
  @@index([reviewStatus])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ApiKey {
  id              String          @id @default(cuid())
  key             String          @unique
  keyHash         String          @unique
  name            String
  userId          String
  permissions     ApiPermission[]
  isActive        Boolean         @default(true)
  status          ApiKeyStatus    @default(ACTIVE)
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  rateLimitMinute Int             @default(60)
  rateLimitHour   Int             @default(1000)
  rateLimitDay    Int             @default(10000)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@index([isActive])
}

/// ===============================
/// RECEIPT OCR IMPORT MODULE
/// Added: receipt ingestion pipeline
/// ===============================

model Store {
  id             String  @id @default(cuid())
  normalizedName String
  rawName        String?
  brand          String?
  company        String?
  siret          String?
  phone          String?
  address        String?
  postalCode     String?
  city           String?
  territory      String /// TerritoryCode lowercase (gp, mq, ...)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipts     Receipt[]
  observations PriceObservation[]

  @@unique([normalizedName, territory])
  @@index([territory])
  @@index([normalizedName])
}

model Receipt {
  id              String   @id @default(cuid())
  source          String   @default("ocr_ticket")
  storeId         String
  territory       String
  receiptDate     DateTime
  receiptTime     String?
  currency        String   @default("EUR")
  itemsCount      Int?
  linesCount      Int?
  subtotalHt      Float?
  totalTtc        Float
  rawOcrText      String?  @db.Text
  confidenceScore Int      @default(0)
  needsReview     Boolean  @default(false)
  checksum        String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store              @relation(fields: [storeId], references: [id])
  items        ReceiptItem[]
  observations PriceObservation[]

  @@index([storeId])
  @@index([territory])
  @@index([receiptDate])
}

model ReceiptItem {
  id               String  @id @default(cuid())
  receiptId        String
  lineIndex        Int
  rawLabel         String
  normalizedLabel  String?
  brand            String?
  category         String?
  subcategory      String?
  quantity         Float?
  unit             String?
  packageSizeValue Float?
  packageSizeUnit  String?
  unitPrice        Float?
  totalPrice       Float
  vatRate          Float?
  barcode          String?
  productId        String?
  confidenceScore  Int     @default(0)
  needsReview      Boolean @default(false)
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipt      Receipt            @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product      Product?           @relation(fields: [productId], references: [id])
  observations PriceObservation[]

  @@index([receiptId])
  @@index([productId])
}

model Product {
  id                   String  @id @default(cuid())
  productKey           String  @unique
  displayName          String
  rawLabel             String
  normalizedLabel      String
  brand                String?
  category             String?
  subcategory          String?
  barcode              String? @unique
  packageSizeValue     Float?
  packageSizeUnit      String?
  primaryImageUrl      String?
  imageSource          String?
  imageSourceType      String?
  imageConfidenceScore Int?
  imageNeedsReview     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receiptItems   ReceiptItem[]
  images         ProductImage[]
  observations   PriceObservation[]
  historyMonthly PriceHistoryMonthly[]
  historyYearly  PriceHistoryYearly[]

  @@index([productKey])
  @@index([category])
  @@index([barcode])
}

model ProductImage {
  id              String  @id @default(cuid())
  productId       String
  imageUrl        String
  thumbnailUrl    String?
  pageUrl         String?
  source          String
  sourceType      String
  confidenceScore Int     @default(0)
  isPrimary       Boolean @default(false)
  needsReview     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isPrimary])
}

model PriceObservation {
  id               String   @id @default(cuid())
  source           String   @default("receipt_ocr")
  receiptId        String?
  receiptItemId    String?
  productId        String?
  territory        String
  storeId          String?
  storeLabel       String
  observedAt       DateTime
  productLabel     String
  normalizedLabel  String
  category         String?
  brand            String?
  barcode          String?
  quantity         Float?
  unit             String?
  packageSizeValue Float?
  packageSizeUnit  String?
  price            Float
  currency         String   @default("EUR")
  confidenceScore  Int      @default(0)
  needsReview      Boolean  @default(false)

  createdAt DateTime @default(now())

  receipt     Receipt?     @relation(fields: [receiptId], references: [id])
  receiptItem ReceiptItem? @relation(fields: [receiptItemId], references: [id])
  product     Product?     @relation(fields: [productId], references: [id])
  store       Store?       @relation(fields: [storeId], references: [id])

  @@index([productId, territory, observedAt])
  @@index([territory, observedAt])
  @@index([storeId])
  @@index([needsReview])
}

model PriceHistoryMonthly {
  id                String   @id @default(cuid())
  productId         String
  territory         String
  year              Int
  month             Int
  avgPrice          Float
  minPrice          Float
  maxPrice          Float
  observationsCount Int      @default(0)
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, territory, year, month])
  @@index([productId, territory, year, month])
}

model PriceHistoryYearly {
  id                String   @id @default(cuid())
  productId         String
  territory         String
  year              Int
  avgPrice          Float
  minPrice          Float
  maxPrice          Float
  observationsCount Int      @default(0)
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, territory, year])
  @@index([productId, territory, year])
}

model ReviewQueueEntry {
  id          String   @id @default(cuid())
  entityType  String /// "receipt" | "receipt_item" | "product" | "product_image"
  entityId    String
  reason      String
  payloadJson Json?
  status      String   @default("pending") /// pending | in_review | approved | rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, entityType])
  @@index([entityId])
}

model PriceAlertEvent {
  id          String   @id @default(cuid())
  productId   String
  territory   String
  eventType   String /// "new_low" | "significant_drop" | "significant_rise"
  oldPrice    Float?
  newPrice    Float
  dropPercent Float?
  storeLabel  String?
  observedAt  DateTime
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([productId, territory])
  @@index([processed])
}

/// ===============================
/// GAMIFICATION MODELS
/// ===============================

model userGamification {
  id                 String    @id @default(cuid())
  userId             String    @unique
  totalPoints        Int       @default(0)
  level              Int       @default(1)
  currentStreak      Int       @default(0)
  longestStreak      Int       @default(0)
  lastActiveDate     DateTime?
  priceReportsCount  Int       @default(0)
  verificationsCount Int       @default(0)
  photosCount        Int       @default(0)
  receiptsCount      Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([totalPoints])
}

model pointsTransaction {
  id          String      @id @default(cuid())
  userId      String
  action      PointAction
  points      Int
  description String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
}

model badge {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  description String
  category    BadgeCategory
  rarity      BadgeRarity
  iconUrl     String?
  points      Int           @default(0)
  requirement Json?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  @@index([category])
  @@index([rarity])
}

model userBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeCode String
  badgeType String?
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeCode])
  @@index([userId])
}

model challenge {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  description String
  type        ChallengeType
  startDate   DateTime
  endDate     DateTime
  target      Int
  reward      Int
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  @@index([type])
  @@index([isActive])
}

model userChallenge {
  id            String    @id @default(cuid())
  userId        String
  challengeCode String
  progress      Int       @default(0)
  completed     Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, challengeCode])
  @@index([userId])
}

/// ===============================
/// BRAND & LEGAL ENTITY MODELS
/// ===============================

model brand {
  id             String      @id @default(cuid())
  name           String      @unique
  normalizedName String      @unique
  description    String?
  logoUrl        String?
  website        String?
  status         BrandStatus @default(ACTIVE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([normalizedName])
}

model legalEntity {
  id         String       @id @default(cuid())
  name       String
  siret      String?      @unique
  siren      String?
  address    String?
  city       String?
  postalCode String?
  country    String       @default("FR")
  status     EntityStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([siret])
  @@index([siren])
}

/// ===============================
/// NOTIFICATION MODELS
/// ===============================

model notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  status    NotificationStatus @default(UNREAD)
  metadata  Json?
  createdAt DateTime           @default(now())
  readAt    DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model notificationPreference {
  id           String                @id @default(cuid())
  userId       String                @unique
  channels     NotificationChannel[]
  priceAlerts  Boolean               @default(true)
  badges       Boolean               @default(true)
  challenges   Boolean               @default(true)
  weekly       Boolean               @default(true)
  emailEnabled Boolean               @default(true)
  pushEnabled  Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([userId])
}

model pushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  auth      String
  p256dh    String
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
}

model priceAlert {
  id             String    @id @default(cuid())
  userId         String
  productId      String
  territory      String
  alertType      AlertType
  targetPrice    Float?
  isActive       Boolean   @default(true)
  triggeredAt    DateTime?
  notifyEmail    Boolean   @default(true)
  notifyPush     Boolean   @default(true)
  notifySms      Boolean   @default(false)
  triggeredCount Int       @default(0)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([isActive])
}

/// ===============================
/// ANALYTICS & PREDICTION MODELS
/// ===============================

model priceIndex {
  id            String   @id @default(cuid())
  territory     String
  year          Int
  month         Int
  indexValue    Float
  inflationRate Float    @default(0)
  monthlyChange Float    @default(0)
  baseValue     Float    @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([territory, year, month])
  @@index([territory, year, month])
}

model categoryIndex {
  id           String   @id @default(cuid())
  territory    String
  category     String
  year         Int
  month        Int
  indexValue   Float
  weight       Float    @default(0)
  contribution Float    @default(0)
  baseValue    Float    @default(100)
  createdAt    DateTime @default(now())

  @@unique([territory, category, year, month])
  @@index([territory, category, year, month])
}

model pricePrediction {
  id             String   @id @default(cuid())
  productId      String
  territory      String
  predictedPrice Float
  confidence     Float
  horizon        Int /// Days ahead
  createdAt      DateTime @default(now())

  @@index([productId, territory])
}

model inflationReport {
  id          String    @id @default(cuid())
  territory   String
  year        Int
  month       Int
  rate        Float
  reportData  Json?
  generatedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([territory, year, month])
  @@index([territory, year, month])
}

model metroReferencePrice {
  id           String   @id @default(cuid())
  productCode  String
  averagePrice Float
  year         Int
  month        Int
  createdAt    DateTime @default(now())

  @@unique([productCode, year, month])
  @@index([productCode])
}

/// ===============================
/// QUOTE & MARKETPLACE MODELS
/// ===============================

model quote {
  id         String      @id @default(cuid())
  requestId  String?     @unique
  requester  String
  email      String
  phone      String?
  details    Json
  status     QuoteStatus @default(PENDING)
  validUntil DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
}

model quoteRequest {
  id            String        @id @default(cuid())
  requesterName String
  requesterType RequesterType
  email         String
  phone         String?
  organization  String?
  message       String
  status        QuoteStatus   @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([email])
}

model marketplaceOffer {
  id          String       @id @default(cuid())
  sellerId    String
  productId   String
  title       String
  description String?
  price       Float
  quantity    Int
  type        String?
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sellerId])
  @@index([productId])
  @@index([status])
}

model marketplacePurchase {
  id         String   @id @default(cuid())
  buyerId    String
  offerId    String
  quantity   Int
  totalPrice Float
  status     String
  createdAt  DateTime @default(now())

  @@index([buyerId])
  @@index([offerId])
}

/// ===============================
/// CREDITS & BILLING MODELS
/// ===============================

model creditBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model creditTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model invoice {
  id        String    @id @default(cuid())
  userId    String
  number    String    @unique
  amount    Float
  currency  String    @default("EUR")
  status    String
  pdfUrl    String?
  metadata  Json?
  issuedAt  DateTime
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([number])
  @@index([status])
}

/// ===============================
/// AUDIT & SYNC MODELS
/// ===============================

model auditLog {
  id         String       @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  result     AuditResult?
  userRole   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime     @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model syncLog {
  id           String    @id @default(cuid())
  source       String
  status       String
  recordsCount Int       @default(0)
  errorMessage String?
  metadata     Json?
  startedAt    DateTime
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([source])
  @@index([status])
  @@index([startedAt])
}

model apiUsage {
  id           String   @id @default(cuid())
  apiKeyId     String
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int?
  timestamp    DateTime @default(now())

  @@index([apiKeyId])
  @@index([timestamp])
}
