// Schema Prisma pour A KI PRI SA YÉ - Backend Institutionnel
// Conforme RGPD et législation française

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Toutes les définitions existantes de pasted2.txt ---
// ... (COLLE ici le contenu intégral de pasted2.txt ci-dessus)

// ==================== AJOUTS POUR RÉSOUDRE LES ERREURS TYPESCRIPT PRISMA ====================

// Modèle ApiKey pour l'authentification API
model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    ApiKeyStatus @default(ACTIVE)
  expiresAt DateTime?
  permissions ApiPermission[]
  createdAt DateTime @default(now())
  @@index([key])
  @@index([userId])
  @@map("api_keys")
}

// Enum du statut d'API Key
enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// Modèle Permission API (granularité des accès)
model ApiPermission {
  id      String @id @default(uuid())
  name    String @unique
  apiKeyId String
  apiKey  ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  // Ajoute ici plus de granularité permissions si nécessaire
  @@index([name])
  @@index([apiKeyId])
  @@map("api_permissions")
}

// Enum SubscriptionTier (utilisable dans TS)
enum SubscriptionTier {
  BASIC
  PRO
  INSTITUTION
}

// ------------------- FIN AJOUTS POUR ERREURS IMPORT -------------------

