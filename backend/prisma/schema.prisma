// Schema Prisma pour A KI PRI SA YÉ - Backend Institutionnel
// Conforme RGPD et législation française

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Utilisateur de l'application (administrateurs, gestionnaires)
/// RGPD: Minimisation des données - uniquement les informations essentielles
/// 
/// Références légales:
/// - Règlement (UE) 2016/679 (RGPD) - Art. 5, 25, 32
model User {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Email (utilisé pour l'authentification)
  /// RGPD: Donnée personnelle - consentement requis
  email     String   @unique @db.VarChar(255)
  
  /// Hash du mot de passe (bcrypt)
  /// RGPD: Art. 32 - Sécurité du traitement
  /// Jamais stocké en clair
  passwordHash String @map("password_hash") @db.VarChar(255)
  
  /// Nom complet de l'utilisateur
  /// RGPD: Donnée personnelle
  name      String   @db.VarChar(255)
  
  /// Rôle de l'utilisateur (pour permissions futures)
  role      UserRole @default(USER)
  
  /// Compte actif ou désactivé
  isActive  Boolean  @default(true) @map("is_active")
  
  /// Date de dernière connexion
  /// RGPD: Traçabilité des accès
  lastLogin DateTime? @map("last_login")
  
  /// Date de création du compte
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de dernière mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  /// Stripe Customer ID (for payment processing)
  /// RGPD: External service identifier
  stripeCustomerId String? @unique @map("stripe_customer_id") @db.VarChar(255)
  
  /// Refresh tokens actifs (pour révocation)
  refreshTokens RefreshToken[]
  
  /// Logs d'audit créés par cet utilisateur
  auditLogs AuditLog[]
  
  /// Profil chat (optionnel - créé si user participe aux discussions)
  chatProfile ChatUserProfile?

  @@index([email])
  @@index([isActive])
  @@index([role])
  @@index([stripeCustomerId])
  @@map("users")
}

/// Refresh tokens pour authentification JWT
/// Stockage pour permettre révocation
/// RGPD: Minimisation - uniquement hash et expiration
model RefreshToken {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Hash du refresh token (SHA-256)
  /// Jamais stocké en clair
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  
  /// Utilisateur propriétaire
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  /// Date d'expiration
  expiresAt DateTime @map("expires_at")
  
  /// Révoqué manuellement (logout, changement mot de passe, etc.)
  isRevoked Boolean  @default(false) @map("is_revoked")
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Rôles utilisateur avec hiérarchie de permissions (Sprint 3)
/// 
/// Hiérarchie (du plus restreint au plus permissif):
/// USER < ANALYSTE < ENSEIGNE < INSTITUTION < SUPER_ADMIN
enum UserRole {
  /// Utilisateur standard - lecture seule
  USER
  
  /// Analyste - lecture étendue + statistiques
  ANALYSTE
  
  /// Enseigne - gestion entités propres
  ENSEIGNE
  
  /// Institution - gestion multi-enseignes
  INSTITUTION
  
  /// Super administrateur - accès complet
  SUPER_ADMIN
}

/// Entité légale représentant une entreprise ou établissement
/// Conforme au système d'identification français SIREN/SIRET
/// 
/// Références légales:
/// - Décret n°82-130 du 9 février 1982 (SIREN)
/// - Article R123-220 du Code de commerce (SIRET)
/// - Règlement (UE) 2016/679 (RGPD) - Art. 5, 25, 32
model LegalEntity {
  /// Identifiant unique interne
  id        String   @id @default(uuid())
  
  /// SIREN: Système d'Identification du Répertoire des ENtreprises
  /// Format: 9 chiffres exactement
  /// Délivré par l'INSEE lors de l'inscription au Répertoire SIRENE
  /// Algorithme de validation: Luhn (clé de contrôle)
  /// @unique car chaque entreprise n'a qu'un seul SIREN
  siren     String   @unique @db.VarChar(9)
  
  /// SIRET: Système d'Identification du Répertoire des ETablissements
  /// Format: 14 chiffres (SIREN + NIC)
  /// NIC = Numéro Interne de Classement (5 chiffres)
  /// Une entreprise peut avoir plusieurs SIRET (un par établissement)
  /// @unique car chaque établissement est unique
  siret     String   @unique @db.VarChar(14)
  
  /// Raison sociale ou dénomination de l'entreprise
  /// Donnée publique issue du Répertoire SIRENE (Open Data)
  /// RGPD: Base légale = Art. 6.1.e (mission d'intérêt public)
  name      String   @db.VarChar(255)
  
  /// Statut de l'entreprise
  /// ACTIVE: En activité
  /// CEASED: Cessation d'activité (radiation, liquidation)
  /// Conforme aux codes de l'INSEE pour le Répertoire SIRENE
  status    EntityStatus @default(ACTIVE)
  
  /// Date de création de l'enregistrement dans notre système
  /// RGPD: Traçabilité des données (Art. 5.2)
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de dernière mise à jour
  /// RGPD: Exactitude et mise à jour des données (Art. 5.1.d)
  updatedAt DateTime @updatedAt @map("updated_at")
  
  /// Enseignes liées à cette entité légale (Sprint 4)
  brands    Brand[]
  
  /// Vérifications d'entreprise (Sprint 11)
  verifications CompanyVerification[]

  @@index([siren])
  @@index([siret])
  @@index([status])
  @@map("legal_entities")
}

/// Énumération des statuts possibles pour une entité légale
/// Conforme aux catégories du Répertoire SIRENE de l'INSEE
enum EntityStatus {
  /// Entreprise en activité
  ACTIVE
  
  /// Entreprise ayant cessé son activité
  /// Inclut: radiation, liquidation, fermeture
  CEASED
}

/// Journal d'audit légal - IMMUABLE (Sprint 3)
/// 
/// Traçabilité complète de toutes les actions sensibles
/// Conformité RGPD Art. 30 (registre des activités de traitement)
/// 
/// RÈGLES STRICTES:
/// - ❌ Aucune modification possible
/// - ❌ Aucune suppression possible
/// - ✅ Création uniquement
/// - ✅ Lecture par utilisateurs autorisés (AUDIT_READ)
model AuditLog {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Utilisateur ayant effectué l'action
  /// RGPD: Responsabilité et traçabilité (Art. 5.2)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  
  /// Rôle de l'utilisateur au moment de l'action
  /// Permet de tracer les permissions effectives
  userRole  UserRole @map("user_role")
  
  /// Action effectuée
  /// Exemples: CREATE_LEGAL_ENTITY, UPDATE_USER_ROLE, LOGIN, etc.
  action    String   @db.VarChar(100)
  
  /// Type d'entité concernée
  /// Exemples: LegalEntity, User, RefreshToken
  entity    String?  @db.VarChar(100)
  
  /// ID de l'entité concernée (si applicable)
  entityId  String?  @map("entity_id") @db.VarChar(255)
  
  /// Résultat de l'action
  result    AuditResult @default(SUCCESS)
  
  /// Message additionnel (erreur, détails, etc.)
  /// Ne doit pas contenir de données sensibles
  message   String?  @db.Text
  
  /// Adresse IP de l'utilisateur
  /// RGPD: Donnée personnelle - à pseudonymiser après 90 jours
  ip        String?  @db.VarChar(45)
  
  /// User-Agent du navigateur/client
  userAgent String?  @map("user_agent") @db.Text
  
  /// Date et heure de l'action (UTC)
  /// Horodatage précis pour traçabilité légale
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userRole])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([result])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Résultat d'une action auditée
enum AuditResult {
  /// Action réussie
  SUCCESS
  
  /// Action échouée (erreur, validation, etc.)
  FAILURE
  
  /// Accès refusé (permissions insuffisantes)
  DENIED
}

/// ==========================================
/// SPRINT 4: MARKETPLACE ECOSYSTEM
/// ==========================================

/// Enseigne commerciale (Brand)
/// Représente une marque ou chaîne de magasins inscrite sur la plateforme
/// Lien obligatoire avec une LegalEntity validée
/// 
/// Règles métier:
/// - Une enseigne doit être liée à une entité légale valide (SIREN/SIRET)
/// - Validation requise par INSTITUTION ou SUPER_ADMIN
/// - Abonnement obligatoire pour publier produits/prix
model Brand {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Nom commercial de l'enseigne
  name      String   @db.VarChar(255)
  
  /// Entité légale associée (SIREN/SIRET validé)
  /// Référence obligatoire pour conformité juridique
  legalEntityId String  @map("legal_entity_id")
  legalEntity   LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Restrict)
  
  /// Statut de l'enseigne
  /// PENDING: En attente de validation
  /// ACTIVE: Validée et opérationnelle
  /// SUSPENDED: Suspendue (non-paiement, violation CGU, etc.)
  status    BrandStatus @default(PENDING)
  
  /// Plan d'abonnement actif
  subscriptionPlan SubscriptionPlan @default(BASIC) @map("subscription_plan")
  
  /// Logo URL (optionnel)
  logoUrl   String?  @map("logo_url") @db.VarChar(500)
  
  /// Description de l'enseigne
  description String? @db.Text
  
  /// Site web de l'enseigne
  website   String?  @db.VarChar(500)
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de dernière mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  /// Magasins de l'enseigne
  stores    Store[]
  
  /// Produits de l'enseigne
  products  Product[]
  
  /// Abonnements
  subscriptions Subscription[]

  @@index([legalEntityId])
  @@index([status])
  @@index([subscriptionPlan])
  @@map("brands")
}

/// Statut d'une enseigne
enum BrandStatus {
  /// En attente de validation institutionnelle
  PENDING
  
  /// Validée et active
  ACTIVE
  
  /// Suspendue (violation, non-paiement, etc.)
  SUSPENDED
}

/// Magasin / Point de vente
/// Représente un point de vente physique d'une enseigne
/// Utilisé pour la géolocalisation et comparaison locale des prix
model Store {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Enseigne propriétaire
  brandId   String   @map("brand_id")
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  
  /// Nom du magasin (ex: "Carrefour City Paris 15")
  name      String   @db.VarChar(255)
  
  /// Adresse complète
  address   String   @db.VarChar(500)
  
  /// Code postal
  postalCode String  @map("postal_code") @db.VarChar(10)
  
  /// Ville
  city      String   @db.VarChar(255)
  
  /// Territoire (pour comparaisons et statistiques)
  /// DOM/COM/France hexagonale
  territory Territory
  
  /// Latitude (pour géolocalisation)
  latitude  Float?   @db.DoublePrecision
  
  /// Longitude (pour géolocalisation)
  longitude Float?   @db.DoublePrecision
  
  /// Magasin actif ou fermé
  isActive  Boolean  @default(true) @map("is_active")
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de dernière mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  /// Prix associés au magasin
  prices    Price[]

  @@index([brandId])
  @@index([territory])
  @@index([city])
  @@index([isActive])
  @@map("stores")
}

/// Territoire géographique
/// Pour segmentation et comparaisons de prix
enum Territory {
  /// France hexagonale (métropole)
  FRANCE_HEXAGONALE
  
  /// Départements d'Outre-Mer
  DOM
  
  /// Collectivités d'Outre-Mer
  COM
}

/// Produit
/// Représente un produit vendu par une enseigne
/// Peut avoir plusieurs prix (un par magasin)
model Product {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Enseigne propriétaire
  /// Un produit ne peut être créé que par une enseigne validée
  brandId   String   @map("brand_id")
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  
  /// Nom du produit
  name      String   @db.VarChar(255)
  
  /// Catégorie produit
  category  String   @db.VarChar(100)
  
  /// Code-barres EAN/GTIN (si disponible)
  /// Permet l'identification unique inter-enseignes
  barcode   String?  @db.VarChar(50)
  
  /// Description du produit
  description String? @db.Text
  
  /// Image URL (optionnel)
  imageUrl  String?  @map("image_url") @db.VarChar(500)
  
  /// Produit actif ou retiré du catalogue
  isActive  Boolean  @default(true) @map("is_active")
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de dernière mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  /// Prix du produit (historique et actuels)
  prices    Price[]
  
  /// Prédictions de prix
  predictions PricePrediction[]

  @@index([brandId])
  @@index([category])
  @@index([barcode])
  @@index([isActive])
  @@map("products")
}

/// Prix d'un produit dans un magasin
/// Historique complet - aucune suppression autorisée
/// 
/// Règles strictes:
/// - Chaque modification de prix crée une nouvelle entrée
/// - Historique conservé indéfiniment pour traçabilité
/// - Détection automatique d'anomalies (variations > seuil)
/// - Audit obligatoire de toute modification
model Price {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Produit concerné
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  /// Magasin concerné
  storeId   String   @map("store_id")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  
  /// Prix (en centimes d'euro pour éviter problèmes de précision)
  /// Ex: 1599 = 15,99€
  price     Int
  
  /// Devise (ISO 4217)
  currency  String   @default("EUR") @db.VarChar(3)
  
  /// Source de la donnée prix
  /// MANUAL: Saisie manuelle par l'enseigne
  /// API: Import via API
  /// INSTITUTION: Relevé institutionnel (vérification)
  source    PriceSource @default(MANUAL)
  
  /// Date d'effet du prix
  /// Permet de planifier des changements de prix futurs
  effectiveDate DateTime @map("effective_date")
  
  /// Date de création de l'enregistrement
  /// RGPD: Traçabilité complète
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([storeId])
  @@index([effectiveDate])
  @@index([createdAt])
  @@map("prices")
}

/// Source d'un prix
enum PriceSource {
  /// Saisie manuelle par l'enseigne
  MANUAL
  
  /// Import automatique via API
  API
  
  /// Relevé institutionnel (contrôle, vérification)
  INSTITUTION
}

/// Prédiction de prix par IA
/// RÈGLES JURIDIQUES STRICTES:
/// - ❌ PAS de promesse de prix futur
/// - ❌ PAS de conseil financier
/// - ✅ Indication probabiliste uniquement
/// - ✅ Mention obligatoire "aide à la décision"
/// - ✅ Historique conservé pour auditabilité
/// 
/// Conformité:
/// - Code de la consommation (pratiques commerciales trompeuses)
/// - Règlement (UE) 2016/679 (RGPD) - Art. 22 (décision automatisée)
model PricePrediction {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Produit concerné
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  /// Territoire concerné
  territory Territory
  
  /// Prix actuel moyen (référence)
  currentPrice Int    @map("current_price")
  
  /// Prix prédit (en centimes)
  predictedPrice Int  @map("predicted_price")
  
  /// Score de confiance (0.0 à 1.0)
  /// Indique la fiabilité de la prédiction
  confidenceScore Float @map("confidence_score") @db.DoublePrecision
  
  /// Version du modèle IA utilisé
  /// Permet traçabilité et reproductibilité
  modelVersion String @map("model_version") @db.VarChar(50)
  
  /// Horizon de prédiction (en jours)
  /// Ex: 7 = prédiction à 7 jours
  horizonDays Int    @map("horizon_days")
  
  /// Date de création de la prédiction
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([territory])
  @@index([createdAt])
  @@map("price_predictions")
}

/// Abonnement d'une enseigne
/// Gère la monétisation B2B de la plateforme
/// 
/// Règles métier:
/// - Abonnement obligatoire pour publier produits/prix
/// - Facturation automatique selon billingCycle
/// - Suspension automatique en cas de non-paiement
model Subscription {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Enseigne abonnée
  brandId   String   @map("brand_id")
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  
  /// Plan d'abonnement
  /// BASIC: Fonctionnalités limitées
  /// PRO: Fonctionnalités étendues + API
  /// INSTITUTION: Accès complet + support premium
  plan      SubscriptionPlan
  
  /// Prix de l'abonnement (en centimes/mois)
  price     Int
  
  /// Cycle de facturation
  /// MONTHLY, QUARTERLY, YEARLY
  billingCycle String @map("billing_cycle") @db.VarChar(20)
  
  /// Statut de l'abonnement
  status    SubscriptionStatus @default(ACTIVE)
  
  /// Date de début
  startedAt DateTime @map("started_at")
  
  /// Date de fin (null = abonnement actif indéfiniment)
  endsAt    DateTime? @map("ends_at")
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de dernière mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  /// Factures associées
  invoices  Invoice[]

  @@index([brandId])
  @@index([plan])
  @@index([status])
  @@map("subscriptions")
}

/// Plan d'abonnement
enum SubscriptionPlan {
  /// Plan basique (limité)
  BASIC
  
  /// Plan professionnel (étendu)
  PRO
  
  /// Plan institutionnel (complet)
  INSTITUTION
}

/// Statut d'abonnement
enum SubscriptionStatus {
  /// Actif
  ACTIVE
  
  /// Annulé (par l'utilisateur)
  CANCELLED
  
  /// Suspendu (non-paiement, etc.)
  SUSPENDED
  
  /// Expiré
  EXPIRED
}

/// Facture
/// Générée automatiquement selon le cycle de facturation
/// Traçabilité complète des paiements
model Invoice {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Abonnement concerné
  subscriptionId String @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  
  /// Montant (en centimes)
  amount    Int
  
  /// Devise
  currency  String   @default("EUR") @db.VarChar(3)
  
  /// Statut de la facture
  status    InvoiceStatus @default(PENDING)
  
  /// Numéro de facture (unique, généré automatiquement)
  invoiceNumber String @unique @map("invoice_number") @db.VarChar(50)
  
  /// Date d'émission
  issuedAt  DateTime @map("issued_at")
  
  /// Date d'échéance
  dueAt     DateTime @map("due_at")
  
  /// Date de paiement (null si non payée)
  paidAt    DateTime? @map("paid_at")
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@index([status])
  @@index([issuedAt])
  @@map("invoices")
}

/// Statut de facture
enum InvoiceStatus {
  /// En attente de paiement
  PENDING
  
  /// Payée
  PAID
  
  /// Annulée
  CANCELLED
  
  /// En retard
  OVERDUE
}

/// Demande de devis
/// Pour entreprises PRO et institutions
/// Permet demandes personnalisées
model QuoteRequest {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Type de demandeur
  requesterType RequesterType @map("requester_type")
  
  /// Email du demandeur
  email     String   @db.VarChar(255)
  
  /// Nom de l'entreprise/institution
  companyName String @map("company_name") @db.VarChar(255)
  
  /// Besoins détaillés
  needs     String   @db.Text
  
  /// Volume estimé (nombre de produits, magasins, etc.)
  estimatedVolume String? @map("estimated_volume") @db.VarChar(255)
  
  /// Territoire(s) concerné(s)
  territory Territory?
  
  /// Statut de la demande
  status    QuoteStatus @default(PENDING)
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de dernière mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  /// Devis généré (si disponible)
  quote     Quote?

  @@index([status])
  @@index([requesterType])
  @@map("quote_requests")
}

/// Type de demandeur de devis
enum RequesterType {
  /// Entreprise professionnelle
  PRO
  
  /// Institution publique
  INSTITUTION
}

/// Statut de demande de devis
enum QuoteStatus {
  /// En attente de traitement
  PENDING
  
  /// Devis envoyé
  SENT
  
  /// Devis accepté
  ACCEPTED
  
  /// Devis rejeté
  REJECTED
}

/// Devis généré
/// Réponse à une QuoteRequest
/// Génération par règles IA déterministes (pas d'hallucination)
model Quote {
  /// Identifiant unique
  id        String   @id @default(uuid())
  
  /// Demande de devis associée
  quoteRequestId String @unique @map("quote_request_id")
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Restrict)
  
  /// Montant proposé (en centimes)
  amount    Int
  
  /// Devise
  currency  String   @default("EUR") @db.VarChar(3)
  
  /// Détails du devis (JSON)
  /// Inclut: breakdown, options, conditions
  details   String   @db.Text
  
  /// Généré par IA ou manuellement
  generatedByAI Boolean @default(true) @map("generated_by_ai")
  
  /// Version du modèle IA (si applicable)
  modelVersion String? @map("model_version") @db.VarChar(50)
  
  /// Date de validité du devis
  validUntil DateTime @map("valid_until")
  
  /// Date d'acceptation (null si non accepté)
  acceptedAt DateTime? @map("accepted_at")
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")

  @@index([quoteRequestId])
  @@map("quotes")
}

// ============================================================================
// SPRINT 8: CERTIFICATION, COMPLIANCE & DATA INTEGRITY
// ============================================================================

/// Certification officielle de la plateforme
/// Label "A KI PRI SA YÉ - Données Économiques Vérifiées"
/// 
/// Références légales:
/// - Loi pour une République numérique (2016) - Transparence algorithmes
/// - RGPD Art. 30 - Registre des activités de traitement
enum CertificationScope {
  PLATFORM      // Certification plateforme entière
  API           // Certification API spécifique
  DASHBOARD     // Certification dashboard institutionnel
  ALGORITHM     // Certification algorithme spécifique
  DATA_SOURCE   // Certification source de données
}

enum CertificationStatus {
  ACTIVE      // Certification valide
  SUSPENDED   // Certification suspendue
  REVOKED     // Certification révoquée
  EXPIRED     // Certification expirée
}

model Certification {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Périmètre de la certification
  scope CertificationScope
  
  /// Version de la certification (ex: "1.0.0")
  version String @db.VarChar(20)
  
  /// Émis par (organisation/autorité)
  issuedBy String @db.VarChar(255)
  
  /// Date d'émission
  issuedAt DateTime @default(now()) @map("issued_at")
  
  /// Valide jusqu'à
  validUntil DateTime @map("valid_until")
  
  /// Statut de la certification
  status CertificationStatus @default(ACTIVE)
  
  /// Hash SHA-256 des critères de certification
  /// Garantit l'intégrité et la traçabilité
  criteriaHash String @map("criteria_hash") @db.VarChar(64)
  
  /// Référence audit externe (optionnel)
  auditReference String? @map("audit_reference") @db.VarChar(100)
  
  /// Métadonnées JSON (critères détaillés, etc.)
  metadata String? @db.Text
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@index([scope])
  @@index([status])
  @@index([validUntil])
  @@map("certifications")
}

/// Registre des algorithmes (transparence algorithmique)
/// Conformité Loi pour une République numérique - Art. L111-7-2
/// 
/// Pas de boîte noire - tous les algorithmes documentés
enum AlgorithmModelType {
  STATISTICAL       // Modèles statistiques (moyenne, régression, etc.)
  MACHINE_LEARNING  // ML (réseaux neurones, etc.)
  RULE_BASED        // Règles déterministes
  HYBRID            // Combinaison
}

model AlgorithmRegistry {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Nom de l'algorithme (ex: "price_prediction_v1")
  name String @unique @db.VarChar(100)
  
  /// Objectif de l'algorithme
  purpose String @db.VarChar(500)
  
  /// Description détaillée
  description String @db.Text
  
  /// Inputs (JSON array de noms de champs)
  inputs String @db.Text
  
  /// Outputs (JSON array de noms de champs)
  outputs String @db.Text
  
  /// Type de modèle
  modelType AlgorithmModelType @map("model_type")
  
  /// Version de l'algorithme
  version String @db.VarChar(20)
  
  /// Méthode de calcul de confiance (expliquée en français)
  confidenceMethod String @map("confidence_method") @db.Text
  
  /// Date de dernière revue
  lastReviewedAt DateTime @map("last_reviewed_at")
  
  /// Publiquement visible (transparence)
  isPublic Boolean @default(true) @map("is_public")
  
  /// Métadonnées JSON (formules mathématiques, etc.)
  metadata String? @db.Text
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@index([name])
  @@index([modelType])
  @@index([isPublic])
  @@map("algorithm_registry")
}

/// Journal d'intégrité des données
/// Hash cryptographique quotidien pour détecter toute altération
/// 
/// Références légales:
/// - RGPD Art. 32 - Sécurité du traitement
/// - Code de commerce - Conservation documents comptables
model DataIntegrityLog {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Nom de la table surveillée
  tableName String @map("table_name") @db.VarChar(100)
  
  /// Nombre d'enregistrements au moment du snapshot
  recordCount Int @map("record_count")
  
  /// Hash SHA-256 des données (triées, normalisées)
  dataHash String @map("data_hash") @db.VarChar(64)
  
  /// Date du snapshot
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([tableName])
  @@index([createdAt])
  @@map("data_integrity_logs")
}

/// Documents de conformité (auto-générés)
/// COMPLIANCE_REPORT, DATA_GOVERNANCE, ALGORITHMIC_TRANSPARENCY, RGPD_RECORDS
enum ComplianceDocumentType {
  COMPLIANCE_REPORT         // Rapport conformité général
  DATA_GOVERNANCE           // Gouvernance des données
  ALGORITHMIC_TRANSPARENCY  // Transparence algorithmes
  RGPD_RECORDS             // Registre RGPD Art. 30
  SECURITY_POLICY          // Politique sécurité
  DATA_RETENTION           // Politique conservation
}

model ComplianceDocument {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Type de document
  type ComplianceDocumentType
  
  /// Version du document (ex: "1.0.0")
  version String @db.VarChar(20)
  
  /// Contenu du document (Markdown)
  content String @db.Text
  
  /// Hash SHA-256 du contenu (intégrité)
  contentHash String @map("content_hash") @db.VarChar(64)
  
  /// Auteur/Générateur
  author String @db.VarChar(255)
  
  /// Révisé par (optionnel)
  reviewedBy String? @map("reviewed_by") @db.VarChar(255)
  
  /// Valide jusqu'à
  validUntil DateTime? @map("valid_until")
  
  /// Métadonnées JSON
  metadata String? @db.Text
  
  /// Date de génération
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([type])
  @@index([version])
  @@index([createdAt])
  @@map("compliance_documents")
}

