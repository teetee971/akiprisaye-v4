// ============================================================

/// Source de données externes (INSEE, DGCCRF, Registres)
/// Traçabilité complète des intégrations avec organismes officiels
/// RGPD: Données publiques uniquement
model ExternalDataSource {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Nom de la source
  /// Exemples: "INSEE", "DGCCRF", "rappel.conso.gouv.fr"
  name String @db.VarChar(255)
  
  /// Type de source
  sourceType DataSourceType
  
  /// URL API ou endpoint
  apiUrl String? @map("api_url") @db.VarChar(500)
  
  /// Licence d'utilisation
  /// Exemple: "Licence Ouverte v2.0"
  licence String @db.VarChar(255)
  
  /// URL de la licence
  licenceUrl String? @map("licence_url") @db.VarChar(500)
  
  /// Fréquence de mise à jour
  updateFrequency UpdateFrequency @map("update_frequency")
  
  /// Dernière synchronisation réussie
  lastSync DateTime? @map("last_sync")
  
  /// Fiabilité estimée (0-100%)
  reliabilityScore Int @default(100) @map("reliability_score")
  
  /// Source active ou inactive
  isActive Boolean @default(true) @map("is_active")
  
  /// Notes techniques
  notes String? @db.Text
  
  /// Date de création
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  recalls ProductRecall[]
  verifications CompanyVerification[]
  logs SourceDataLog[]
  
  @@index([sourceType])
  @@index([isActive])
  @@map("external_data_sources")
}

/// Rappels de produits (DGCCRF / rappel.conso.gouv.fr)
/// Protection du consommateur - alertes officielles
model ProductRecall {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// ID source externe (rappel.conso.gouv.fr)
  externalId String? @map("external_id") @db.VarChar(255)
  
  /// Source de données
  sourceId String @map("source_id")
  source ExternalDataSource @relation(fields: [sourceId], references: [id])
  
  /// Nom du produit rappelé
  productName String @map("product_name") @db.VarChar(500)
  
  /// Marque
  brand String? @db.VarChar(255)
  
  /// Catégorie de produit
  category String @db.VarChar(255)
  
  /// Motif du rappel
  /// Exemple: "Présence de Listeria", "Risque d'étouffement"
  reason String @db.Text
  
  /// Gravité
  severity RecallSeverity
  
  /// Numéro de lot
  lotNumber String? @map("lot_number") @db.VarChar(255)
  
  /// Code-barres (GTIN/EAN)
  barcode String? @db.VarChar(14)
  
  /// Date de publication du rappel
  publishedAt DateTime @map("published_at")
  
  /// Date de fin de la procédure de rappel
  endsAt DateTime? @map("ends_at")
  
  /// URL de la notice officielle
  noticeUrl String? @map("notice_url") @db.VarChar(500)
  
  /// Image du produit
  imageUrl String? @map("image_url") @db.VarChar(500)
  
  /// Consignes aux consommateurs
  consumerInstructions String? @map("consumer_instructions") @db.Text
  
  /// Rappel actif ou terminé
  isActive Boolean @default(true) @map("is_active")
  
  /// Date de création dans notre système
  createdAt DateTime @default(now()) @map("created_at")
  
  /// Date de mise à jour
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@index([barcode])
  @@index([category])
  @@index([severity])
  @@index([publishedAt])
  @@index([isActive])
  @@map("product_recalls")
}

/// Vérification d'entreprises (SIREN/SIRET)
/// Registres officiels - données publiques uniquement
model CompanyVerification {
  /// Identifiant unique
  id String @id @default(uuid())
  
  /// Lien vers LegalEntity si existant
  legalEntityId String? @map("legal_entity_id")
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id])
  
  /// Source de vérification
  sourceId String @map("source_id")
  source ExternalDataSource @relation(fields: [sourceId], references: [id])
  
  /// SIREN vérifié
  siren String @db.VarChar(9)
  
  /// SIRET vérifié (si applicable)
  siret String? @db.VarChar(14)
  
  /// Nom légal vérifié
  legalName String @map("legal_name") @db.VarChar(500)
  
  /// Nom commercial
  tradeName String? @map("trade_name") @db.VarChar(500)
  
  /// Statut juridique
  /// Exemple: "SARL", "SAS", "Micro-entreprise"
  legalStatus String? @map("legal_status") @db.VarChar(100)
  
  /// Statut d'activité
  activityStatus CompanyActivityStatus @default(ACTIVE) @map("activity_status")
  
  /// Adresse siège social
  address String? @db.VarChar(500)
  
  /// Code postal
  postalCode String? @map("postal_code") @db.VarChar(10)
  
  /// Ville
  city String? @db.VarChar(255)
  
  /// Département
  department String? @db.VarChar(10)
  
  /// Date de création de l'entreprise
  companyCreatedAt DateTime? @map("company_created_at")
  
  /// Date de cessation (si applicable)
  companyCeasedAt DateTime? @map("company_ceased_at")
  
