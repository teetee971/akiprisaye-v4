{
  "name": "auto-scraper",
  "version": "1.0.0",
  "type": "module",
  "description": "Scraping automatique multi-sources des prix DOM-TOM — Open Data gov + OpenFoodFacts + OpenPrices",
  "scripts": {
    "scrape": "node scrape.mjs",
    "scrape:deep": "node scrape.mjs --deep-scan",
    "scrape:fuel": "node scrape.mjs --source fuel",
    "scrape:food": "node scrape.mjs --source food",
    "scrape:fresh": "node scrape.mjs --source fresh",
    "scrape:catalogue": "node scrape.mjs --source catalogue",
    "scrape:bqp": "node scrape.mjs --source bqp",
    "scrape:services": "node scrape.mjs --source services",
    "scrape:loyer": "node scrape.mjs --source loyer",
    "scrape:medicaments": "node scrape.mjs --source medicaments",
    "scrape:octroi-mer": "node scrape.mjs --source octroi-mer",
    "scrape:com": "node scrape.mjs --source com",
    "scrape:grossistes": "node scrape.mjs --source grossistes",
    "dry-run": "node scrape.mjs --dry-run",
    "dry-run:deep": "node scrape.mjs --dry-run --deep-scan",
    "scan": "node scrape-product.mjs",
    "scan:panier": "node scrape-product.mjs --panier --territory all --output both",
    "scan:ean": "node scrape-product.mjs --output both"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.4",
    "firebase-admin": "^12.1.0",
    "openai": "^4.47.1"
  }
}
