{
    "name": "aki-chat-ia-local",
    "version": "2.1.0",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:ci": "vite build 2>&1 | tee build.log && ! grep -iE \"didn't resolve|deprecated|circular dependency|chunk size exceeds|eval is discouraged|dynamic import could not be analyzed\" build.log || true",
        "preview": "vite preview --port 4173",
        "test": "vitest",
        "test:ci": "SKIP_OCR_TESTS=true vitest run --passWithNoTests",
        "typecheck": "tsc --noEmit",
        "typecheck:ci": "tsc --noEmit --pretty false",
        "lint": "eslint .",
        "lint:ci": "eslint . --max-warnings=0",
        "audit:ci": "npm audit --audit-level=moderate",
        "axe": "npm run build && npm run preview & sleep 5 && axe http://localhost:4173 --exit --tags wcag2a,wcag2aa,wcag21a,wcag21aa && kill $!",
        "axe:ci": "npm run preview & sleep 5 && axe http://localhost:4173 http://localhost:4173/#/anti-crise http://localhost:4173/#/comparateur http://localhost:4173/#/observatoire --exit --tags wcag2a,wcag2aa,wcag21a,wcag21aa && kill $!",
        "lhci": "lhci autorun",
        "lhci:collect": "lhci collect",
        "lhci:assert": "lhci assert",
        "ci:strict": "npm run typecheck:ci && npm run lint:ci && npm run build:ci && npm run test:ci && npm run audit:ci",
        "ci:full": "npm run ci:strict && npm run axe:ci && npm run lhci",
        "data:sign": "node scripts/data-signing/signData.mjs",
        "data:verify": "node scripts/data-signing/verifyData.mjs",
        "data:sign-all": "for file in data/*.json; do node scripts/data-signing/signData.mjs \"$file\" \"${file%.json}.proof.json\"; done",
        "observations:add": "node scripts/add-observation.js",
        "observations:generate": "node scripts/generate-index.js",
        "import:off": "cd backend && tsx ../scripts/import-openfoodfacts.ts",
        "seed:stores": "cd backend && tsx ../scripts/seed-stores.ts",
        "cap:sync": "cap sync",
        "cap:build": "npm run build && cap sync",
        "cap:open:android": "cap open android",
        "android:dev": "npm run build && cap sync android && cap open android"
    },
    "dependencies": {
        "@openfoodfacts/openfoodfacts-nodejs": "^2.0.0-alpha.19",
        "@tanstack/react-query": "^5.90.7",
        "@tensorflow/tfjs": "^4.22.0",
        "@vitejs/plugin-react": "^4.6.0",
        "@zxing/browser": "^0.1.5",
        "@zxing/library": "^0.21.3",
        "chart.js": "^4.5.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "exceljs": "^4.4.0",
        "firebase": "^12.5.0",
        "framer-motion": "^12.26.2",
        "fuse.js": "^7.1.0",
        "jspdf": "^4.0.0",
        "leaflet": "^1.9.4",
        "leaflet.markercluster": "^1.5.3",
        "lodash": "^4.17.21",
        "lucide-react": "^0.562.0",
        "react": "^18.3.1",
        "react-chartjs-2": "^5.3.1",
        "react-dom": "^18.3.1",
        "react-helmet-async": "^2.0.5",
        "react-leaflet": "^4.2.1",
        "react-router-dom": "^7.6.3",
        "react-webcam": "^7.2.0",
        "recharts": "^3.3.0",
        "tailwind-merge": "^3.4.0",
        "tesseract.js": "^6.0.1"
    },
    "devDependencies": {
        "@axe-core/cli": "^4.11.0",
        "@capacitor/android": "^8.0.0",
        "@capacitor/cli": "^7.4.4",
        "@capacitor/core": "^8.0.0",
        "@eslint/js": "^9.15.0",
        "@lhci/cli": "^0.15.1",
        "@tailwindcss/postcss": "^4.1.17",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "autoprefixer": "^10.4.21",
        "axe-core": "^4.11.1",
        "eslint": "^9.15.0",
        "eslint-plugin-react": "^7.37.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "jsdom": "^27.1.0",
        "prettier": "^3.3.3",
        "tailwindcss": "^4.1.17",
        "terser": "^5.44.1",
        "typescript": "^5.9.3",
        "vite": "^7.2.2",
        "vite-plugin-static-copy": "^3.1.4",
        "vitest": "^4.0.8"
    },
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    }
}
