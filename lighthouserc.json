{
  "_comment": "Configuration Lighthouse CI pour pre-merge checks. URLs principales testées: / et /#/comparateur",
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/#/comparateur"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage",
        "emulatedFormFactor": "mobile",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638,
          "cpuSlowdownMultiplier": 4
        },
        "budgets": [
          {
            "resourceSizes": [
              {
                "resourceType": "script",
                "budget": 350
              },
              {
                "resourceType": "image",
                "budget": 500
              },
              {
                "resourceType": "stylesheet",
                "budget": 50
              },
              {
                "resourceType": "total",
                "budget": 1200
              }
            ],
            "resourceCounts": [
              {
                "resourceType": "script",
                "budget": 15
              },
              {
                "resourceType": "third-party",
                "budget": 5
              }
            ]
          }
        ]
      }
    },
    "assert": {
      "_comment": "Assertions pre-merge: mode warn pour ne pas bloquer les PRs mais signaler les problèmes",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],

        "largest-contentful-paint": ["warn", { "maxNumericValue": 3500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "speed-index": ["warn", { "maxNumericValue": 4000 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],

        "uses-text-compression": "warn",
        "offscreen-images": "warn",
        "color-contrast": "warn",
        "image-alt": "warn",
        "meta-viewport": "warn",
        "document-title": "warn",
        "html-has-lang": "warn",
        "valid-lang": "warn",
        "aria-allowed-attr": "warn",
        "aria-required-attr": "warn",
        "button-name": "warn",
        "link-name": "warn",
        "label": "warn",
        "list": "warn",
        "listitem": "warn",
        "tabindex": "warn",
        "heading-order": "warn",
        
        "resource-summary:script:size": ["warn", { "maxNumericValue": 350000 }],
        "resource-summary:image:size": ["warn", { "maxNumericValue": 500000 }],
        "resource-summary:total:size": ["warn", { "maxNumericValue": 1200000 }],
        
        "unused-javascript": ["warn", { "maxLength": 1 }],
        "modern-image-formats": "warn",
        "uses-responsive-images": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
