{
  "name": "akiprisaye-frontend",
  "private": true,
  "version": "3.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "lint": "eslint src --ext .ts,.tsx,.js,.jsx --cache --cache-location .eslintcache",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "lint:full": "npm run lint -- --no-cache",
    "lint:changed": "node scripts/lint-changed.mjs",
    "lint:ci": "node scripts/lint-changed.mjs --max-warnings=0",
    "lint:full:ci": "npm run lint:full",

    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:ci": "node scripts/typecheck-changed.mjs",

    "test": "vitest run --config vitest.config.ts",
    "test:ci": "npm run test",

    "build:ci": "npm run build",
    "smoke:preview": "npm run build && node scripts/smoke-preview.mjs",

    "verify:pages-api": "node scripts/verify-pages-api.mjs",
    "verify:placeholder-routing": "npm run build && node scripts/verify-placeholder-routing.mjs",
    "verify:redirects-order": "node scripts/verify-redirects-order.mjs",
    "test:spa": "npm run build && node scripts/test-spa.mjs",

    "audit": "npm audit --omit=dev --audit-level=high",
    "audit:ci": "npm audit --omit=dev --audit-level=high",

    "axe:ci": "echo \"axe check placeholder: no dedicated suite configured\"",
    "lhci": "echo \"lhci placeholder: no dedicated config found\"",

    "e2e": "playwright test",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@turf/turf": "^6.5.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^11.1.0",
    "framer-motion": "^11.18.0",
    "fuse.js": "^7.0.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "i18next-http-backend": "^2.7.3",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^13.5.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.15.4",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.55.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.0.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}