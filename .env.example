# === Price Variation Education Module (ressources/pourquoi-prix-varie-sans-changement) - PRIORITY 19 ===

# Price Variation Education Module (default: true)
# Set to 'true' to enable the educational module at /ressources/pourquoi-prix-varie-sans-changement
# Explains why prices can vary without product changes - descriptive, pedagogical, non-analytical
# NO predictions, NO advice, NO judgments (normal/abnormal/excessive), NO responsibility attribution
# Explains FACTORS, not certified CAUSES
VITE_FEATURE_PRICE_VARIATION_EDU=true

# === Promotions Education Module (ressources/comprendre-promotions-prix-barres) - PRIORITY 20 ===

# Promotions and Strikethrough Prices Education Module (default: true)
# Set to 'true' to enable the educational module at /ressources/comprendre-promotions-prix-barres
# Explains promotions, discounts and strikethrough prices - descriptive, pedagogical, neutral
# NO advice, NO ratings, NO recommendations, NO commercial analysis
# NO predictions, NO responsibility attribution, NO user data collection
# Strictly descriptive and pedagogical for public neutral observatory
VITE_FEATURE_PROMOTIONS_EDU=true

