# Application Version
APP_VERSION=1.6.1

# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project credentials

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Feature Flags

# === v1.6.0 - PR #1: Assistant + FAQ Étendue ===

# Intelligent Assistant v1.6.0 (default: true)
VITE_FEATURE_ASSISTANT=true

# Extended FAQ System v1.6.0 (default: true)
VITE_FEATURE_FAQ=true

# === v1.6.1 - PR #2: Abonnements + Gratification ===

# Visual Gratification System v1.6.1 (default: true)
VITE_FEATURE_GRATIFICATION=true

