{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client"],
    "allowJs": true,
    "noUncheckedIndexedAccess": false
  },
  "include": [
    "src/data/pricing.ts",
    "src/pages/Pricing.tsx",
    "src/vite-env.d.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
