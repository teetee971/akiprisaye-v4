    "@zxing/browser": "^0.1.5",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "firebase": "^12.9.0",
    "framer-motion": "^12.34.3",
    "fuse.js": "^7.1.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.575.0",
    "papaparse": "^5.5.3",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.4",
    "react-is": "^19.2.4",
    "react-joyride": "^2.9.3",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "web-vitals": "^5.1.0",
