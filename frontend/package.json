{
  "name": "akiprisaye-frontend",
  "private": true,
  "version": "3.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx --cache --cache-location .eslintcache",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:ci": "tsc -p tsconfig.ci.json",
    "test:ci": "vitest run --config vitest.config.ts",
    "audit": "npm audit --omit=dev --audit-level=high",
    "audit:ci": "npm audit --omit=dev --audit-level=high",
    "postbuild": "node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('public/_redirects','dist/_redirects');\"",
    "lint:ci": "cd .. && npm run lint:ci",
    "build:ci": "npm run build"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react": "^10.41.0",
