{
  "name": "akiprisaye-frontend",
  "private": true,
  "version": "3.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx --cache --cache-location .eslintcache",
    "lint:full": "npm run lint -- --no-cache",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "test": "vitest run",
    "smoke:preview": "npm run build && node scripts/smoke-preview.mjs",
    "lint:changed": "node scripts/lint-changed.mjs",
    "typecheck:ci": "node scripts/typecheck-changed.mjs",
    "lint:ci": "node scripts/lint-changed.mjs --max-warnings=0",
    "lint:full:ci": "npm run lint:full",
    "build:ci": "npm run build",
    "test:ci": "npm run test",
    "audit:ci": "npm audit --audit-level=high",
    "axe:ci": "echo \"axe check placeholder: no dedicated suite configured\"",
    "lhci": "echo \"lhci placeholder: no dedicated config found\"",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "verify:pages-api": "node scripts/verify-pages-api.mjs",
    "verify:placeholder-routing": "npm run build && node scripts/verify-placeholder-routing.mjs",
    "verify:redirects-order": "node scripts/verify-redirects-order.mjs",
    "test:spa": "npm run build && node scripts/test-spa.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@turf/turf": "^6.5.0",
    "@types/leaflet": "^1.9.21",
    "@zxing/library": "^0.21.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^11.1.0",
    "framer-motion": "^11.18.0",
    "fuse.js": "^7.0.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "i18next-http-backend": "^2.7.3",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "lodash": "^4.17.21",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.5.3",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^13.5.0",
    "react-joyride": "^2.9.3",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tesseract.js": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^28.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "terser": "^5.46.0",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.1.6",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "tmp": "^0.2.5"
  }
}
